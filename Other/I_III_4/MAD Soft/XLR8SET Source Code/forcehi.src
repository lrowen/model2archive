	title	'Forcehi - reserves or releases low memory'	print	short,nomacourbase:equ	0d000h			;Does not conflict with XLR8SET	psect	ourbaseVERSION:defm	'forcehi - Force Drivers to high memory - '	defm	'Version   1(6)  15-May-93   '	defb	0ah	defm	'Copyright 1990-1993, M. A. D. Software, All Rights Reserved.'	defb	0dh;----------------------------------------------------------------------------;	FORCEHI by M. A. D. Software.  Copyright 1990, All Rights Reserved;	The purchaser may not transfer or provide copies of the binary,;	object, executable or source of this program to any third party;	without prior written permission from M. A. D.  Software.;	The purchaser may make any modifications to the source that are;	required to customize this software to a single target system.;	Once modified, M. A. D. has no obligation to provide support for;	any part of the program.;----------------------------------------------------------------------------;	Edit History	EDIT edit VERSION version Version HISTORY history;	Edit	1	Initial version.;			??-May-90  M. A. D.  Software;	Edit	2	Maintain a copy of the command line so that trailing;			commands may be executed after FORCEHI completes.;			??-May-90  M. A. D.  Software;	Edit	3	Partially Implemented the -t option;			??-May-90  M. A. D.  Software;	Edit	4	Code cleanup;			31-Apr-90  M. A. D. Software;	Edit	5	Source cleanup and update to current standards;			1-May-93  M. A. D. Software;	Edit	6	Merge in modern command parsing and make program;			match documentation.;			15-May-93  M. A. D. Software;-----------------------------------------------------------------------------ldos:	macro	#1	ld	a,#1	rst	28h	endm;	Constants for operationlowbase:equ	08f0hlowlim:	equ	206h@cmndi:	equ	24			;Issue a command@abort:	equ	21			;Abort execution@dsply:	equ	10			;Display a string@exit:	equ	22			;Exit	header	'Read and process command-line options'begin:	ld	de,ourbuf			ld	bc,82	ldir;	Now we start processing the command line.  Each time we find a;	devicespec or modulename we place it in the pattern buffer and;	attempt to display those devices.  	ld	hl,ourbuf		;<2>Use our buf from now on	xor	a			;Contains defaults and command line	ld	(inoption),a		;Reset option flagparnxt:	ld	a,(hl)			;Pick up character	cp	' '			;Space?	jr	nz,parnsp		;No	xor	a	ld	(inoption),a		;Not an option anymoreparadv:	inc	hl	jr	parnxt			;Skipparnsp:	cp	0dh			;End?	jp	z,parend		;End of parms to parse	cp	';'			;Start of trailing command?	jr	nz,opt1			;No, treat as an errorskpspa:	inc	hl			;Skip any leading spaces	ld	a,(hl)	cp	' '	jr	z,skpspa	ld	(nxtcmd),hl		;Store trailing command position	jr	parend			;End of parms to parseopt1:	cp	'-'			;Option switch	jp	z,paropt		;Handle option	ld	b,a			;Save character	ld	a,(inoption)		;Did we process an option last?	or	a	ld	a,b			;Get back original character	jp	nz,opt2			;Possibly a -abc option format	jr	badopt	eject;	Parse option switches and parametersparopt:	inc	hl			;Bump past '-'	ld	a,(hl)			;Get option code	ld	(inoption),a		;Remember we were hereopt2:	or	20h			;Fold case	cp	'r'			;<2>	jr	z,gor			;<2>	ift	0;	cp	'T'			;<2>;	jr	z,gob			;<2>;	cp	't'			;<2>;	jr	z,gob			;<2>	endif	0	cp	'f'	jr	z,gof	cp	'q'	jr	nz,badoptgoq:	ld	(quiet),a		;Set non-zero	jr	paradv			;<2>gor:	ld	(reset),a		;<2>	jr	paradv			;<2>gof:	ld	(silence),a		;<2>Say nothing no matter what	ld	(quiet),a		;<2>Just do the job.	jr	paradv	ift	0gob:	ld	a,(hl)			;<2>	cp	' '			;<2>	jr	z,gob			;<2>	cp	0dh			;<2>	jr	z,rdy			;<2>False alarm	cp	'('			;<2>Allow several delims	jr	c,stx			;<2>Any will do	jr	badopt			;<2>Huh?stx:	ld	b,a			;<2>Save delimeter	inc	hl			;<2>	push	hl			;<2>stxr:	ld	a,(hl)			;<2>	cp	b			;<2>Look for match	jr	z,etx			;<2>	cp	0dh			;<2>	jp	z,badopt		;<2>	inc	hl			;<2>	jr	stxr			;<2>etx:	push	hl			;<3>nomov1:	pop	hl			;<3>	ld	(hl),0dh		;<2>Terminate string	ex	(sp),hl			;<2>Get base back	ldos	@cmndr			;<2>Execute command now	pop	hl			;<2>Get back addr	jr	dnxt			;<2>Jump back into common	endifbadopt:	ld	hl,VERSION	ldos	@dsply	ld	hl,USAGE	ldos	@dsply	ld	hl,0	ldos	@exit	header	'Either install or remove or module from low memory'parend:	call	search			;Search for our driver	jr	nz,notpres;	Our dummy module is already present.	ld	a,(reset)		;Do they want it removed?	or	a	jr	z,alreadyl		;Already loaded;	Undo memory module	xor	a	push	ix	pop	hl	ld	b,40lpa:	ld	(hl),a	inc	hl	djnz	lpa	ld	(lowlim),ix		;Limit	ld	a,(quiet)	or	a	jr	nz,no1	ld	hl,UNLOADED	ldos	@dsplyno1:	ld	hl,(nxtcmd)		;Was there more commands on cmd line?	ld	a,h	or	l	jr	nz,end3			;Yes	ldos	@exit			;No, exit (HL==0)end3:	ldos	@cmndi			;Execute subsequent commandsalreadyl:	ld	a,(silence)	or	a	jr	nz,no1	ld	hl,DUPERR	ldos	@dsply	ldos	@abort	eject;	Okay, we are not there, so see what they want donenotpres:ld	a,(reset)	or	a	jr	nz,nothere	ld	de,(lowlim)	ld	hl,header	ld	bc,hdrlen	ldir;	Dummy header is in place	ld	hl,ourend	inc	hl	ld	(lowlim),hl		;Set end of memory marker	ld	a,(quiet)	or	a	jr	nz,no1	ld	hl,LOADED	ldos	@dsply	jr	no1nothere:ld	a,(silence)	or	a	jr	nz,no1			;Just exit quietly	ld	hl,NFERR	ldos	@dsply	ldos	@abort	header	'Search for the memory module in low memory';-----------------------------------------------------------------------------;	This routine searches low memory until it find the last driver;	and then compares that modules name against the one we are;	looking for.;		Z	Last module is ours;		NZ	Last module is not ours;-----------------------------------------------------------------------------search:	ld	iy,lowbase		;Low base to start atsnext:	push	iy	pop	de	ld	hl,(lowlim)	or	a	sbc	hl,de	jp	z,eof			;At eof;	Bump our pointer to the next structure	ld	l,(iy+2)	ld	h,(iy+3)	inc	hl	push	iy	pop	bc			;Save last driver base	push	hl	pop	iy	jr	snext			;Do next one;	We now have found the "last" driver.  It is in BCeof:	ld	hl,OURLBL	ld	e,c	ld	d,b	push	bc	pop	ix	ld	b,ourlen	inc	de	inc	de	inc	de	inc	de	inc	decmpz:	ld	a,(de)	cp	(hl)	ret	nz	inc	hl	inc	de	djnz	cmpz	ret	header	'Read-Only/Read-Write data'USAGE:	defm	'?Usage: forcehi [-qfr?h] '	defm	'[; command...]'	defb	0ah	defm	'Options are: (? or h displays this message)'	defb	0ah	defm	'-q  Runs silently, only displaying errors'	defb	0ah	defm	'-r  Releases memory reserved previously by FORCEHI'	defb	0ah	defm	'-f  Runs silently and does not display error messages'	defb	0dhLOADED:	defm	'Low memory is now reserved.  Use  "forcehi -r" to release'	defm	' low memory.'	defb	0dhUNLOADED:defm	'Low memory is now released.'	defb	0dhNFERR:	defm	'?Low memory has not been reserved by forcehi.'	defb	0dhDUPERR:	defm	'?Low memory is already reserved by forcehi.'	defb	0dhourend:	equ	12fah			;Picked locationheader:	jr	thisadr	defw	ourend	defb	ourlenOURLBL:	defm	'ForceHi'ourlen:	equ	$-OURLBL	defw	0thisadr:defw	0hdrlen:	equ	$-headerquiet:	defb	0silence:defb	0reset:	defb	0inoption:defb	0			;<6>nxtcmd:	defw	0			;<6>ourbuf:	defb	85%0			;<2>Store command line here	end	begin			;