 			    339	
 			    340	;	This piece of code apparently resets the pattern matcher in the time
 			    341	;	chip by repeatedly reading the A0=0 location.  There are 64 bits
 			    342	;	that must match or else the sequencer resets, but this implies that
 			    343	;	this may not always happen.
 			    344		
  53C4 	CD2D55              345	SELECT:	CALL	SHADOW
  53C7 	2AB656              346		LD	HL,(BASE)		;Get base address
  53CA 	010400              347		LD	BC,4			;Make this a READ operation
  53CD 	09	            348		ADD	HL,BC			;Adjust address
  53CE 	0641	            349		LD	B,41H			;Access READ address 65 times
  53D0 	7E	            350	RESLP	LD	A,(HL)			;Access
  53D1 	10FD	            351		DJNZ	RESLP
 			    352		
 			    353	;	This code enables the chip by accessing the correct sequence of
 			    354	;	addresses
 			    355	
  53D3 	0602	            356		LD	B,2			;This sequence is repeated twice
  53D5 	C5	            357	SELLP:	PUSH	BC
  53D6 	3EC5	            358		LD	A,0C5H			;C5
  53D8 	CDEE53              359		CALL	WRITE
  53DB 	3E3A	            360		LD	A,3AH			;3A
  53DD 	CDEE53              361		CALL	WRITE
  53E0 	3EA3	            362		LD	A,0A3H			;A3
  53E2 	CDEE53              363		CALL	WRITE
  53E5 	3E5C	            364		LD	A,5CH			;5C
  53E7 	CDEE53              365		CALL	WRITE
  53EA 	C1	            366		POP	BC
  53EB 	10E8	            367		DJNZ	SELLP
  53ED 	C9	            368		RET
