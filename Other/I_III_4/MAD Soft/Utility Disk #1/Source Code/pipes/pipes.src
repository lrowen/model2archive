	title	'pipes - Connects commands together'	print	short,nomac		;Source packed for compact printing.	psect	02600h			;;	Pipes accepts the following syntaxes:;	pipes [options] program1 [| program2] [< file|device];	      [>[>] file|device] [; [new options] program1 ....];	A semicolon may be used to have multiple isolated commands on the;	same command line.  Redirection and options reset at a semicolon.VERSION:defm	'Pipes - Connects commands together - '	defm	'Version   1(1) 1-Jun-93   '	defb	0ah	defm	'Copyright 1993, M. A. D. Software, All Rights Reserved.'	defb	0dh;	Edit	History	EDIT edit VERSION version Version HISTORY history;	Edit	1	Initial version.;			1-Jun-93  M. A. D.  Software	ref	'TRSDOS6/SRC'ldos:	macro	#1	ld	a,#1	rst	28h	endm;	Constants for operationRENEW:	equ	1RECAT:	equ	2DEBUG:	equ	0			;Can be set higher for debuggingKIDCB:	equ	208h+DEBUG		;LS-DOS 6SIDCB:	equ	220h+DEBUG		;LS-DOS 6DODCB:	equ	210h+DEBUG		;LS-DOS 6@@EXIT:	equ	1b0bh+DEBUG		;LS-DOS 6 Address of dispatch code for					;@EXIT, @ABORT and other exit codesSYS1PAT:equ	1			;Patch SYS1 to lose extra CRSYS1CR:	equ	1eb9h			;LS-DOS 6 Location of SYS1 CR callOVRLY$:	equ	0069h			;LS-DOS 6 Current overlay byteSTACK$:	equ	0380h+DEBUG		;System Stack start location	header	'Save command and relocate driver to high memory';	We begin here.  LS-DOS gives us HL pointing at the first item after;	the program name in the system command buffer.  First, we make a copy.begin:	ld	de,fstbuf+module	;Make copy of system command buffer.	ld	bc,80			;Copy entire length, although some	ldir				;of the data copied is useless.	ld	a,(@@EXIT)	cp	0c3h			;Are we there already?	jr	z,norun			;Can't run if we are already there	cp	03eh			;What should be there in 6.x	jr	nz,unkver		;Don't try this, version mismatch	ld	(savexit+module),a;	Code goes here that locates and sets HIGH$ region to use	ld	de,modname+module	ldos	@gtmod	jr	z,already		;Module already exists	ld	hl,0	ld	b,h	ldos	@high$			;Locate current position of HIGH$	ld	de,lastby+1		;Compute size of our module	or	a	sbc	hl,de			;Compute new HIGH$	ld	b,0	ldos	@high$			;Store new HIGH$	inc	hl			;HIGH$ is one byte below driver	jr	z,already		;Setting HIGH$ failed - abort	ld	hl,NOLOAD		;This error is caused byabomsg:	ldos	@dsply			;CFLAG$ locking high$ or if the	ldos	@abort			;OS is corrupted.norun:	ld	hl,NORUNM	jr	abomsgunkver:	ld	hl,UNVER	jr	abomsg	ejectalready:ld	(ourhigh+module),hl	;Store location of high$+1	ld	b,h			;Save starting position	ld	c,l	ld	ix,ptab			;Point at table of patchesnxttab:	ld	l,(ix)			;Read an entry from the table	inc	ix	ld	h,(ix)	ld	a,h			;Is the entry 0000?	or	l	jr	z,ready			;All patches made	ld	de,module		;Get assembly base address	add	hl,de			;Point at absolute location	push	hl			;Save for store	ld	a,(hl)			;Read word to adjust	inc	hl	ld	h,(hl)	ld	l,a	add	hl,bc			;Add in new base address	ex	de,hl			;Put result in de	pop	hl			;Get address to edit back	ld	(hl),e			;Store adjusted word	inc	hl	ld	(hl),d	inc	ix			;Advance to next table entry	jr	nxttab			;Do next table entryready:	ld	hl,module	ld	de,(ourhigh+module)	ld	bc,lastby	ldir	ld	hl,(ourhigh+module)	ld	de,start	add	hl,de	jp	(hl)PATCH1:	defb	30%0			;Space for any field corrections	header	'Actual PIPES module - Hook module into operating system'module:	equ	$			;Offset to start of module	setloc	0			;Make relocation computation simplehdr:	jr	hdr			;Start of driver (no entry point)	defw	lastby			;Last byte of driver (last HIGH$)PATA1:	equ	$-2	defb	5			;Length of module namemodname:defm	'PIPES'			;Module name	defb	0			;Used so string can be used in GTMODstart:	ld	hl,(@@EXIT+1)		;Entry point from unrelocated code	ld	(savexit+1),hl		;Save Original OS code PATA2:	equ	$-2	ld	a,0c3h			;Branch to our code on an exit	ld	(@@EXIT),a		;or similar abort;	All bytes after this point must be in the module.	ld	hl,ournxt		;Point at our service routinePATA3:	equ	$-2	ld	(@@EXIT+1),hl		;Patch that into the OS	ld	hl,fstbuf		;Point at start of our bufferPATA4:	equ	$-2itsnxt:	ld	de,cmdbuf		;Reentry for additional commandsPATA5:	equ	$-2	xor	a			;Reset flags, option and state	ld	(redirin),aPATA6:	equ	$-2	ld	(redirect),aPATA7:	equ	$-2	ld	(pipe),aPATA8:	equ	$-2	ld	a,0ffh	ld	(nullin),aPATA9:	equ	$-2	header	'Parse redirection options';	First we scan the command line looking for any redirection that;	is to be done in this command sequence.cpycmd:	ld	a,(hl)	cp	'>'			;Redirection output?	jr	z,parred		;Handle redirection	cp	'<'			;Redirection input?	jr	z,redin			;Handle redirection	cp	';'			;Start of next command?	jr	z,parcmd		;Handle for next command	cp	0dh			;Have we reached the end of the line	jr	z,cpyend		;Yes, begin parsing options	ld	(de),a			;Copy this character	inc	de			;Advance source & destination pointers	inc	hl	ld	a,0dh	ld	(de),a	jr	cpycmd			;Get next byte;	Handle < redirectredin:	ld	(redirin),a		;Enable redirection of inputPATB1:	equ	$-2	inc	hl	call	skipspa			;Skip to next item (filespec)PATB2:	equ	$-2	cp	0dh	jr	z,badop1		;No next item, abort	ld	bc,innamePATB3:	equ	$-2	ld	d,15donxti:	ld	(bc),a			;Copy filespec into buffer	inc	bc	ld	a,3	ld	(bc),a			;Pre-terminate the input spec.	dec	d	jr	z,badop1renxti:	inc	hl			;Get next character	ld	a,(hl)	cp	0dh			;Is it the end of line?	jr	z,cpyend		;End of input filespec	cp	' '			;How about a space?	jr	z,renxti		;Also end of input filespec	cp	';'			;Or a semi-colon	jr	z,parcmd		;End of input filespec	cp	'>'			;Output redirection spec	jr	nz,donxti		;Get next redirection char	eject;	Handle > redirectparred:	ld	b,RENEW			;Enable redirection of output	inc	hl	ld	a,(hl)			;Get next character	cp	'>'			;Is it also a >?	jr	nz,nocat		;No, a normal redirection	ld	b,RECAT			;Append to existing output file	inc	hl			;nocat:	ld	a,b	ld	(redirect),aPATC1:	equ	$-2	call	skipspa			;Skip to next item (filespec)PATC2:	equ	$-2	cp	0dh	jr	z,badop1		;No next item, abort	ld	bc,outname		;Zero filled bufferPATC3:	equ	$-2	ld	d,15donxt:	ld	(bc),a			;Copy filespec into buffer	inc	bc	ld	a,3	ld	(bc),a			;Pre-terminate output filename	dec	dbadop1:	jp	z,badopt		;Jumps to jumps for space savingsPATC4:	equ	$-2renxt:	inc	hl	ld	a,(hl)			;Get next character	cp	0dh	jr	z,cpyend		;End of line, end of filespec	cp	' '	jr	z,renxt			;End of filespec	cp	';'	jr	nz,donxt		;Get next redirection char	header	'Save anything following the ; and check redir filespecs';	If the user specified a ;, save remainder of command line for;	execution later on.parcmd:	inc	hl	call	skipspa			;Skip any trailing blanksPATC5:	equ	$-2	cp	0dh			;Did we hit end of line?	jr	z,cpyend		;Then no second command	ld	(nxtcmd),hl		;Store position of next command.PATC6:	equ	$-2cpyend:	ld	a,(redirin)		;Are we redirecting stdin?PATD1:	equ	$-2	or	a	jr	z,noin			;No	ld	hl,inname		;Get the name and put it in a FCBPATD2:	equ	$-2	ld	de,fcbinPATD3:	equ	$-2	push	hl	ldos	@fspec	pop	de	jp	nz,broken		;Syntax error in filespecPATD4:	equ	$-2noin:	ld	a,(redirect)		;Are we redirecting stdout?PATD5:	equ	$-2	or	a	jr	z,noout			;No	ld	hl,outname		;Get the name and put it in a FCBPATD6:	equ	$-2	ld	de,fcboutPATD7:	equ	$-2	push	hl	ldos	@fspec	pop	de	jp	nz,brokenPATD8:	equ	$-2	header	'Start processing command line options';	Now we start processing the command line.  Each time we find a;	devicespec or modulename we place it in the pattern buffer and;	attempt to display those devices.  noout:	ld	hl,cmdbuf		;Point at start of command bufferPATE1:	equ	$-2	xor	a			;Contains defaults and command line	ld	(inoption),a		;Reset option flagPATE2:	equ	$-2parnxt:	ld	a,(hl)			;Pick up character	cp	' '			;Space?	jr	nz,parnsp		;No	xor	a	ld	(inoption),a		;Not an option anymorePATE3:	equ	$-2paradv:	inc	hl	jr	parnxt			;Skipparnsp:	cp	'-'			;Option switch	jr	z,paropt		;Handle option	ld	b,a			;Save character	ld	a,(inoption)		;Did we process an option last?PATE4:	equ	$-2	or	a	ld	a,b			;Get back original character	jr	nz,opt2			;Possibly a -abc option format;	Here we read a non-option character, treat as command to execute	jr	parend;	Parse option switches and parametersparopt:	inc	hl			;Bump past '-'	ld	a,(hl)			;Get option code	ld	(inoption),a		;Remember we were herePATE5:	equ	$-2opt2:	or	20h			;Fold case	cp	'n'			;Return a NULL if anyone asks	jr	z,gon	cp	'e'			;Return an EOF if anyone asks	jr	z,goe	cp	'r'			;Return a <RETURN> if anyone asks	jr	z,gor	cp	's'			;Return a <SPACE> if anyone asks	jr	z,gos	cp	'd'			;Specify drive for pipe storage	jr	nz,badopt	eject;	-d  -  Read drive number to use for pipe storageskpbl:	inc	hl	ld	a,(hl)	cp	' '	jr	z,skpbl	or	a	jr	z,badopt	cp	'0'			;Test drive number	jr	c,badopt	cp	'7'+1	jr	nc,badopt	ld	(FILE1DR),aPATE6:	equ	$-2	ld	(FILE2DR),aPATE7:	equ	$-2	jr	paradv;	-n -r -e -s - Specify what the first program gets on a readgoe:	ld	a,1ch			;Return a EOF	jr	gocomgos:	ld	a,' '			;Return a SPACE	jr	gocomgor:	ld	a,0dh			;Return a CR	jr	gocomgon:	ld	a,00h			;Return a NULLgocom:	ld	(nullin),a		;Normally a 0xffPATE8:	equ	$-2	jr	paradv;	Here a bad parameter was detected, so abort with usage messagebadopt:	ld	hl,VERSION		;Print title and version code	ldos	@dsply	ld	hl,BOPTMSG		;Display usage information	ldos	@dsply	jr	qbroken	header	'Process commands and pipe control and handle errors';	Here we have the input command, now take our current position;	and start to analyze the current command.parend:	ld	a,(hl)	or	a	jr	z,finish		;Our end indicator	cp	' '	jr	nz,fstbyt	inc	hl	jr	parendfstbyt:	push	hl	jr	fstbyt2nxtchr:	ld	a,(hl)			;Get a characterfstbyt2:cp	0dh			;End?	jp	z,fndend		;Yes, all donePATF1:	equ	$-2	cp	'|'			;Found a pipe	jr	z,fndpipe		;Process pipe controls;	Redirection of input and output would go here	inc	hl			;Advance pointer	jr	nxtchr			;Next character;	Something went wrong in accessing a pipe - bail out!broken:	push	de	call	pipecl			;Close any open pipesPATF2:	equ	$-2	ld	hl,BROKENPPATF3:	equ	$-2	ldos	@dsply	pop	hlnxtltr:	ld	a,(hl)			;Get a character (usually from FCB)	cp	' '			;Is it printable?	jr	c,fdone			;Anything control character stops dsp	ld	c,a			;Display this character	ldos	@dsp	inc	hl			;Bump pointer	jr	nxtltr			;Do next characterfdone:	ld	hl,BROKEN2PATF4:	equ	$-2	ldos	@dsply	jr	qbrokenxbroken:ld	hl,BROKENXPATF5:	equ	$-2	ldos	@dsplyqbroken:ld	hl,0ffffh	jr	finish2	header	'Exiting - put operating system back the way it was'finish:	ld	hl,(nxtcmd)PATG1:	equ	$-2	ld	a,h	or	l	ld	de,0	ld	(nxtcmd),dePATG2:	equ	$-2	jp	nz,itsnxt		;Do the next commandPATG3:	equ	$-2	ex	de,hl			;get the zero from above into HLfinish2:push	hl	ld	a,(savexit)PATG4:	equ	$-2	ld	(@@EXIT),a	ld	hl,(savexit+1)PATG5:	equ	$-2	ld	(@@EXIT+1),hl	ifdef	SYS1PAT	ld	a,(OVRLY$)		;Find out current overlay	and	0fh	sub	3h			;Is it SYS1? (Don't ask why SYS1==3)	jr	nz,noact		;No, so we don't have to do anything	ld	(OVRLY$),a		;Make current overlay invalid	endif	;SYS1PATnoact:	ld	hl,0	ld	b,h	ldos	@high$	ld	de,(ourhigh)PATG6:	equ	$-2	or	a	inc	hl	sbc	hl,de	jr	nz,norest	ld	hl,lastby	add	hl,de	ldos	@high$norest:	pop	hl	ldos	@exit	header	'Process a pipe and make stdin/stdout connections';	Here we have a pipe, so we need to direct the output of this;	process into the next.fndpipe:ld	a,0dh	ld	(hl),a			;Terminate this command	ld	(startnxt),hlPATG7:	equ	$-2	call	doinputPATG8:	equ	$-2	jr	nz,broken;	Now create the output pipe since we know we need one.	ld	a,(pipe)PATH1:	equ	$-2	or	'0'	xor	1			;Flip flop between 1 and 2	ld	(pipe),aPATH2:	equ	$-2	ld	(FILE2ID),aPATH3:	equ	$-2	ld	de,FILE2FCBPATH4:	equ	$-2	ld	b,0	ld	hl,file2bufPATH5:	equ	$-2	ldos	@init	jp	nz,broken		;Can't open a pipePATH6:	equ	$-2	ld	a,(DODCB)		;Save output DCB	ld	(DODCB+3),a	ld	hl,(DODCB+1)	ld	(DODCB+4),hl	ld	a,17h			;Flag output as routed	ld	(DODCB),a	ld	(fixdo),aPATH7:	equ	$-2	ld	hl,FILE2FCBPATH8:	equ	$-2	ld	(DODCB+1),hl	jr	usesin2			;Execute command	header	'Last command completes, process next or finish up';	Here is where we return to when the program we ran terminates;	Part of this looks a lot like the entrance to @EXIT/@ABORT calls.ournxt:	ld	sp,STACK$	ei	push	hl	call	pipecl			;Close the pipesPATI1:	equ	$-2	pop	hl	ld	a,h	or	l	jp	nz,xbrokenPATI2:	equ	$-2	ld	hl,(startnxt)		;Get pointer to where we are in cmdPATI3:	equ	$-2	inc	hl	jp	parendPATI4:	equ	$-2;	Here we have a semicolon, so we only hook up stdin to any existing;	pipe.fndend:ld	a,0dh	ld	(hl),a			;Terminate this command	ld	(startnxt),hlPATI5:	equ	$-2	inc	hl	ld	(hl),0	call	doinputPATI6:	equ	$-2	jp	nz,brokenPATI7:	equ	$-2	xor	a	ld	(pipe),aPATI8:	equ	$-2	ld	a,(redirect)PATI9:	equ	$-2	or	a	jr	nz,dored1	ifund	SYS1PAT	ld	c,27			;Move cursor up one line	ldos	@dsp			;To fight what SYS1 does	endif	;SYS1PAT	jr	usesin2	ejectdored1:	ld	de,fcboutPATJ1:	equ	$-2	ld	b,0	ld	hl,file2bufPATJ2:	equ	$-2	ldos	@init	jr	z,open2	cp	2ah			;This error is ok	jp	nz,broken		;Can't open a pipePATJ3:	equ	$-2open2:	ld	a,(redirect)PATJ4:	equ	$-2	cp	RECAT	jr	nz,open3	ldos	@peof			;Append to existing fileopen3:	ld	a,(DODCB)		;Save output DCB	ld	(DODCB+3),a	ld	hl,(DODCB+1)	ld	(DODCB+4),hl	ld	a,17h			;Flag output as routed	ld	(DODCB),a	ld	hl,fcboutPATJ5:	equ	$-2	ld	(DODCB+1),hl	ld	(fixdo),aPATJ6:	equ	$-2	ifdef	SYS1PATusesin2:ld	a,0f3h			;Force load of SYS1/SYS	ld	hl,usesin3PATJ7:	equ	$-2	push	hl			;Overlay control requires this	rst	28husesin3:xor	a	ld	(SYS1CR),a	ld	(SYS1CR+1),a	ld	(SYS1CR+2),a	else	;SYS1PATusesin2:	endif	;SYS1PAT	pop	hl	ldos	@cmndi			;Execute command;	Skipspa - skips down a string until a non-space character is found;		Useful for parsing command line parameters and leading space;		suppresion in numeric fields.skipspa:ld	a,(hl)			;Get a character	cp	' '			;Is it a space?	ret	nz			;Not a space, so return to caller	inc	hl	jr	skipspa			;Look at next character	header	'Open stdin(*si)/*ki inputs and connect to pipes if needed';	Handle connecting appropriate input to the next program.;	This can be:;		A pipe from a previously-run program;		stdin (default);		White hole  (-n -s -r);		Redirected inputdoinput:ld	a,(nullin)		;Are we faking out stdin?PATK1:	equ	$-2	cp	0ffh	jr	nz,isnull	ld	a,(redirin)		;Is this a redirected input?PATK2:	equ	$-2	or	a	jr	z,noredin		;Normal	ld	de,fcbinPATK3:	equ	$-2	jr	incomnoredin:ld	a,(pipe)		;Is the input a pipe?PATK4:	equ	$-2	or	a	ret	z			;Use standard input for this process	ld	(FILE1ID),a		;Mark itPATK5:	equ	$-2	ld	de,FILE1FCBPATK6:	equ	$-2incom:	ld	b,0	ld	hl,file1buf		;256 byte buffer for operationPATK7:	equ	$-2	ldos	@open	ret	nz			;Pipe missing!	ld	a,(SIDCB)		;Save input DCB	ld	(SIDCB+3),a	ld	hl,(SIDCB+1)	ld	(SIDCB+4),hl	ld	(SIDCB+1),de	ld	a,15h			;Flag input as routed	ld	(SIDCB),a	ld	(fixsi),aPATK8:	equ	$-2	xor	a			;Return Z result	ld	(redirin),a		;Redir only works on start of pipePATK9:	equ	$-2	ret	ejectisnull:	ld	hl,(KIDCB+1)	ld	(KIDCB+4),hl	ld	hl,ournullPATL1:	equ	$-2	ld	(KIDCB+1),hl	xor	a	retournull:ld	a,(nullin)		;Get action to takePATL2:	equ	$-2	cp	1ch			;Do we fake an EOF?	jr	z,noeof	cp	a			;Force Z	ret				;Return to callernoeof:	or	a			;Force NZ	ret	header	'Close any pipes that are open and restore stdin/stdout';	Closes any pipes that are open and resets any redirectionpipecl:	ld	a,(nullin)PATL3:	equ	$-2	cp	0ffh	jr	z,nofx2	ld	hl,(KIDCB+4)	ld	(KIDCB+1),hl	ld	a,0ffh	ld	(nullin),aPATL4:	equ	$-2nofx2:	ld	a,(fixsi)PATL5:	equ	$-2	or	a	jr	z,nofx3	ld	a,(SIDCB+3)	ld	(SIDCB),a	ld	de,(SIDCB+1)		;Get FCB to close	ld	hl,(SIDCB+4)	ld	(SIDCB+1),hl	xor	a	ld	(fixsi),aPATL6:	equ	$-2	ldos	@closenofx3:	ld	a,(fixdo)PATL7:	equ	$-2	or	a	ret	z	ld	a,(DODCB+3)	ld	(DODCB),a	ld	de,(DODCB+1)		;Get FCB to close	ld	hl,(DODCB+4)	ld	(DODCB+1),hl	ldos	@close	xor	a	ld	(fixdo),aPATL8:	equ	$-2	retPATCH2:	defb	40%0			;Patch space for any field corrections	header	'Relocatable data - read-only and read-write'BROKENP:defm	'?Can''t continue - Broken pipe on file "'	defb	03hBROKEN2:defm	'"'	defb	0dhBROKENX:defm	'?Broken pipe - Program aborted'	defb	0dhredirin:defb	0			;Stdin on program 1 is redirectedredirect:defb	0			;Stdout on program n is redirectedinoption:defb	0			;- detectedoutname:defb	16%0			;Stdout redirect filespecinname:	defb	16%0			;Stdin redirect filespecnxtcmd:	defw	0			;Pointer to command following ;pipe:	defb	0			;Pipe is in use (and which)fixsi:	defb	0			;SI needs to be reset before exitfixdo:	defb	0			;DO needs to be reset before exitnullin:	defb	0ffh			;Program 1 input choicestartnxt:defw	0savexit:defb	3%0			;Save OS code we patchourhigh:defw	0			;High$ value after we installFILE1FCB:defm	'PIPE'			;Pipe 1 FCBFILE1ID:defm	'X'	defm	':'FILE1DR:defm	'0'			;Drive number is patched in	defb	25%0FILE2FCB:defm	'PIPE'			;Pipe 2 FCBFILE2ID:defm	'X'	defm	':'FILE2DR:defm	'0'			;Drive number is patched in	defb	25%0fcbin:	defb	32%0			;FCB for program 1 stdin redirectfcbout:	defb	32%0			;FCB for program n stdout redirectcmdbuf:	defb	81%0			;Working line bufferfstbuf:	defb	81%0			;Command line buffer (original)file1buf:defb	128%0			;Pipe 1 I/O buffer	defb	128%0file2buf:defb	128%0			;Pipe 2 I/O buffer	defb	128%0lastby:	equ	$			;End of relocatable module	resloc	header	'Non-relocatable read-only data'BOPTMSG:defm	'?Usage: pipes [-d n] [-snre] program1 [| program2] ...'	defm	'[| program n]'	defb	0ah	defm	'              [< file|device] [>[>] file|device]'	defb	0ah	defm	'              [; next command group for pipes program]'	defb	0ah	defm	'Options are: (? or h displays this message)'	defb	0ah	defm	'-d n  Specify drive for PIPE files to be stored on.'	defb	0ah	defm	'-s    Input to first program will be endless <SPACE>'	defm	' characters.'	defb	0ah	defm	'-n    Input to first program will be endless NULLs'	defb	0ah	defm	'-r    Input to first program will be endless <RETURN>s'	defb	0ah	defm	'-e    First program will receive EOF if input is attempted'	defb	0dhNOLOAD:	defm	'?Pipes cannot reserve memory'	defb	0dhNORUNM:	defm	'?Pipes cannot be run from within pipes'	defb	0dhUNVER:	defm	'?Pipes not compatible with this operating system version'	defb	0dhptab:	defw	PATA1,PATA2,PATA3,PATA4,PATA5,PATA6,PATA7,PATA8,PATA9	defw	PATB1,PATB2,PATB3,PATC1,PATC2,PATC3,PATC4,PATC5,PATC6	defw	PATD1,PATD2,PATD3,PATD4,PATD5,PATD6,PATD7,PATD8	defw	PATE1,PATE2,PATE3,PATE4,PATE5,PATE6,PATE7,PATE8	defw	PATF1,PATF2,PATF3,PATF4,PATF5	defw	PATG1,PATG2,PATG3,PATG4,PATG5,PATG6,PATG7,PATG8	defw	PATH1,PATH2,PATH3,PATH4,PATH5,PATH6,PATH7,PATH8	defw	PATI1,PATI2,PATI3,PATI4,PATI5,PATI6,PATI7,PATI8,PATI9	defw	PATJ1,PATJ2,PATJ3,PATJ4,PATJ5,PATJ6,PATJ7	defw	PATK1,PATK2,PATK3,PATK4,PATK5,PATK6,PATK7,PATK8,PATK9	defw	PATL1,PATL2,PATL3,PATL4,PATL5,PATL6,PATL7,PATL8	defw	0			;End of relocation patches	end	begin			;begin is first instruction to do.