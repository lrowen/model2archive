	title	'Mapmem - Memory Module Mapping and Consistency Checker'	header	'Parse - Parse command line and set internal flags'	print	short,nomac	psect	2600h;	Mapmem analyzes memory and locates all memory modules residing in;	low or high memory.  It then figures out what logical disk drives;	or character devices the drivers handle.  Any other modules are;	displayed in their own section.VERSION:defm	'Mapmem - Memory Map and Consistency Checker - '	defm	'Version  1(4)  27-Jul-93'	defb	0ah	defm	'Copyright 1990,1993, M. A. D. Software,  '	defm	'All Rights Reserved.'	defb	0dh;	Edit History	EDIT edit VERSION version Version HISTORY history;	Edit	1	Initial version, not released.;			10-May-90  M. A. D. Software;	Edit	2	Reworked to take advantage of standard modules;			for command line parameters and display operations.;			14-May-93  M. A. D. Software;	Edit	3	Source cleanup for distribution (no code changes);			15-May-93  M. A. D. Software;	Edit	4	Changed string file to have INI extension.;			27-Jul-93  M. A. D. Software	ref	'TRSDOS6/SRC';LISTALL:equ	1			;If defined, included files are listedldos:	macro	#1	ld	a,#1	rst	28h	endm;	Constants for operationLOLIMIT:equ	206h			;End of low memory driversLOWSTART:equ	8f0h			;Base address of low memory driversHIGH$:	equ	40eh			;Start of the high memory driversDRVCNT:	equ	40			;Number of memory modules to handleSTRSIZE:equ	32			;Size of each memory module entryIDMAX:	equ	16			;Maximum number of chars in nameDESMAX:	equ	40			;Maximum number of chars in descript.LENOFF:	equ	IDMAX+DESMAX		;Total record sizeNUMDES:	equ	51			;Maximum number of names to handleMAXDCB:	equ	20			;Maximum number of DCBs to handleDCBSTRSZ:equ	5			;Size of each DCB structure	eject;	The first thing to do is to test for default parameters from;	the defaults file.begin:	push	hl			;Save command line pointer	ld	de,cmdbuf		;Buffer to put options/commands in	call	default			;Read default options from DEFAULTS	ld	a,' '			;Insert a space between any defaults	ld	(de),a			;and command line information	inc	de	pop	hl			;Get pointer back to command linecpycmd:	ld	a,(hl)	cp	'>'			;Redirection?	jr	z,parred		;Handle redirection	cp	';'			;Start of next command?	jr	z,parcmd		;Handle for next command	cp	0dh	jr	z,cpyend	ld	(de),a	inc	de	inc	hl	jr	cpycmd;	Handle > redirectparred:	ld	a,RENEW			;Enable redirection of output	ld	(redirect),a		;Enable redirection of output	inc	hl	ld	a,(hl)			;Get next character	cp	'>'			;Is it also a >?	jr	nz,nocat	ld	a,RECAT	ld	(redirect),a	inc	hlnocat:	call	skipspa			;Skip to next item (filespec)	cp	0dh	jp	z,badopt		;No next item, abort	ld	bc,outname		;Null-filled bufferdonxt:	ld	(bc),a			;Copy filespec into buffer	inc	bcrenxt:	inc	hl	ld	a,(hl)	cp	0dh			;End of filename?	jr	z,cpyend	cp	'.'			;If they use a dot,	jr	nz,renxt1		;No	ld	a,'/'			;Convert to a slash so we accept both	jr	donxt			;Get next character	ejectrenxt1:	cp	' '			;Did we end the filename this way?	jr	z,renxt	cp	';'			;Or perhaps a subsequent command found	jr	nz,donxt		;Get next redirection char;	If the user specified a ;, save remainder of command line for;	execution later on.parcmd:	inc	hl	call	skipspa			;Skip any trailing blanks	cp	0dh			;Did we hit end of line?	jr	z,cpyend		;Then no second command	ld	(nxtcmd),hl		;Store position of next command.cpyend:	xor	a	ld	(de),a			;Terminate command line options	call	outinit			;Initialize redirection (in OUTPUT);	Now we start processing the command line.  Each time we find a;	devicespec or modulename we place it in the pattern buffer and;	attempt to display those devices.  	ld	hl,cmdbuf		;Point at start of command buffer	xor	a			;Contains defaults and command line	ld	(inoption),a		;Reset option flagparnxt:	ld	a,(hl)			;Pick up character	cp	' '			;Space?	jr	nz,parnsp		;No	xor	a	ld	(inoption),a		;Not an option anymoreparadv:	inc	hl	jr	parnxt			;Skipparnsp:	or	a			;End?	jp	z,parend		;End of parms to parse	cp	'-'			;Option switch	jp	z,paropt		;Handle option	ld	b,a			;Save character	ld	a,(inoption)		;Did we process an option last?	or	a	ld	a,b			;Get back original character	jp	nz,opt2			;Possibly a -abc option format;	Here we read a non-option character, treat as an error	jp	badopt	eject;	Parse option switches and parametersparopt:	inc	hl			;Bump past '-'	ld	a,(hl)			;Get option code	ld	(inoption),a		;Remember we were hereopt2:	or	20h			;Fold case	cp	'r'			;Drivers only	jr	z,gor	cp	'm'			;Memory Summary	jr	z,gom	cp	's'			;Alias for Memory Summary	jr	z,gom	cp	'e'			;Devices only	jr	z,goe	cp	'p'			;Output to *PR (Printer)	jr	z,gop	cp	't'			;Strip headers	jr	z,got			;	cp	'd'			;Display lengths in Decimal	jp	nz,badopt;	-d  -  Display Length in Decimals	ld	(decimal),a		;Set non-zero	jr	paradv			;Move to next item;	-m or -s  -  Memory Summary Onlygom:	ld	(devices),a		;Disable device display	ld	(drivers),a		;Disable driver display	xor	a	ld	(summary),a		;Enable summary only	jr	paradv;	-e  -  Devices Onlygoe:	ld	(summary),a		;Disable summary	ld	(drivers),a		;Disable drivers	xor	a	ld	(devices),a		;Enable device display	jp	paradv;	-p  -  Let More pausegop:	ld	a,MORESIZ		;Enable more by specifying size of	ld	(more),a		;first page.  This can look strange	jp	paradv			;if first page is exactly MORELIM					;in size since MORE won't kick in.	eject;	-r  -  Drivers Onlygor:	ld	(summary),a		;Disable summary	ld	(devices),a		;Disable devices	xor	a	ld	(drivers),a		;Enable drivers	jp	paradv;	-t  -	Strip Titlesgot:	ld	(titles),a		;All titles are omitted	jp	paradv;	Here a bad parameter was detected, so abort with usage messagebadopt:	ld	hl,VERSION		;Print title and version code	ldos	@dsply	ld	hl,BOPTMSG		;Display usage information	ldos	@dsply	ldos	@abort			;Do not execute additional commandsend1:	ld	a,(more)		;<2>If MORE is active, handle cases	or	a			;<2>(Is it active	jr	z,end2			;<2>No)	cp	2+1			;<2>caused by DOS CR/CR/LS-DOS	jr	nc,end2			;<2>scrolling our text off.	ld	a,1			;<2>Force -More- prompt to occur	ld	(more),a		;<2>	ld	hl,NOMORE		;<2>	ldos	@dsply			;<2>	ldos	@key			;<2>	call	odmore			;<2>end2:	call	outclose		;Flush output buffers and close stdout	ld	hl,(nxtcmd)		;Was there more commands on cmd line?	ld	a,h	or	l	jr	nz,end3			;Yes	ldos	@exit			;No, exit (HL==0)end3:	ldos	@cmndi			;Execute subsequent commands	header	'Load descriptions from MAPMEM/INI file';	Locate the string file and load the contents into our internal;	database.  These strings are used to print descriptions for the;	various drivers and modules found.  This file can be updated to;	include additional modules at anytime.parend:	ld	hl,destbl	ld	(nxtptr),hl	ld	hl,filebuf	ld	de,filefcb	ld	b,0	ldos	@open	jp	nz,ateof2		;No file, so forget it.;	We found the string file, so start processing entries	xor	a	ld	(lincnt),a		;Reset line counter	ld	(lincnt+1),anextlin:ld	hl,(lincnt)	inc	hl	ld	(lincnt),hlnextbyt:call	getbyte	jp	nz,ateof	cp	1ah	jp	z,ateof			;EOF byte	cp	0dh	jr	z,nextlin	cp	' '	jr	z,nextbyt		;Keep looking	cp	09	jr	z,nextbyt		;Keep looking	cp	'#'	jr	nz,notcom;	Here we have a commentcomlp:	call	getbyte			;Read next byte	jp	nz,ateof		;Bomb off	cp	0dh			;End of line	jr	nz,comlp		;Keep looking	jr	nextlin			;Process next line	eject;	Here we have a valid line entrynotcom:	ld	de,(nxtptr)	push	de	pop	ix			;Put header string here	ld	hl,IDMAX	add	hl,de	push	hl	pop	iy			;Put description here	ld	hl,LENOFF	add	hl,de	ld	(nxtptr),hl		;Start next record here	ld	b,IDMAX	jr	bot1top1:	call	getbyte	jr	nz,ateof	cp	' '	jr	z,nfield	cp	09	jr	z,nfield	cp	0dh	jr	z,syntaxbot1:	ld	(ix),a			;Store character	inc	ix	djnz	top1			;Do another byte	jr	syntaxnextlin1:ld	(iy),03	jr	nextlinnfield:	ld	(ix),3	ld	b,DESMAXtop2:	call	getbyte	jr	nz,ateof	cp	';'	jr	z,comlp	cp	0dh	jr	z,nextlin1	ld	(iy),a			;Store character	inc	iy	djnz	top2			;Do another byte	ejectsyntax:	ld	hl,SYN1			;A syntax error	ld	de,msgbuf	call	strcpy	ld	hl,(lincnt)	ld	de,decbuf	ld	a,' '	ld	(de),a	inc	de	ldos	@hexdec	ex	de,hl	ld	(hl),3zerlp:	dec	hl	ld	a,(hl)	cp	' '	jr	z,matx	jr	zerlpmatx:	ld	de,msgbuf	call	strcat	ld	hl,SYN2	call	strcat	ld	hl,msgbuf	call	ostring	ldos	@abort;	The first activity is to locate all drivers and add them to our;	internal tables.ateof:	ld	de,filefcb	ldos	@closeateof2:	ld	ix,ourtable		;Point at our tables	ld	hl,(LOLIMIT)		;Get stopping point	ld	(limit),hl	ld	iy,LOWSTART		;Place to start search	call	search			;Search low memory	jr	z,mz1			;End matched end of drv region	eject;	Here the last driver in low memory does not indicate the same;	position as the low memory free pointer.  This is bad.	ld	hl,WARN1	call	ostring	ld	hl,WARN11	call	ostringmz1:	ld	de,(HIGH$)		;Get high$	inc	de	ld	a,d	or	e	jr	z,nohigh		;Skip upper memory search	ld	hl,0h			;Roll-over from 0ffffh	ld	(limit),hl		;Set that	push	de	pop	iy			;(HIGH$)	call	search	jr	z,nohigh		;End matched end of drive region	ld	hl,WARN2	call	ostring	ld	hl,WARN21	call	ostring	header	'Display summary of low and high memory usage';	At this point, our table contains all legally configured drivers;	and possibly some that don't make any sense.;	There may be drivers hidden inside currently-running executables,;	but they are not protected by HIGH$.nohigh:	ld	a,(summary)		;Should we display a summary?	or	a	jp	nz,trydriver		;No, skip to disk driver section	ld	a,1	ld	(prev),a		;Flag that this section output text;	Generate the high and low memory summary information.	ld	de,msgbuf		;Use this buffer to construct a line	ld	hl,MEM1			;First text string	call	strcpy			;Copy to working buffer	ld	de,08f0h		;Start of low memory drivers	call	ohex16			;Append hex value to working buffer	ld	hl,MEM2	call	strcat2			;Append to working buffer	ld	hl,msgbuf	call	ostring			;Now print finished line.	ld	de,0			;Cylinder 0	ld	c,0			;Drive 0 (Hopefully we booted from it)	ld	hl,filebuf		;<2>Buffer to store sector	ldos	@rdsec			;Read BOOT/SYS LOW marker	jr	z,okx			;Read was successful	ld	hl,RDERR		;Error reading the boot sector	call	ostring			;Some information may be faultyokx:	ld	hl,MEM3			;Start composing the next line	ld	de,msgbuf	call	strcpy	ld	de,(filebuf+6)		;<2>Read Disk free value	call	ohex16			;Add to working buffer	ld	hl,MEM4	call	strcat2	ld	hl,msgbuf	call	ostring			;Display second line	ld	hl,MEM5	ld	de,msgbuf	call	strcpy			;Start third line of summary	ld	de,(206h)		;The current low memory	push	de	call	ohex16			;Display LOW$	eject	ld	hl,MEM6	call	strcat2	ld	hl,1300h		;End of available LOW$ (for all 6.x)	pop	de	or	a	sbc	hl,de			;HL = remains	ld	de,filebuf		;<2>DE buffer to play in	ldos	@hexdec			;Convert to decimal	ld	a,3	ld	(de),a			;Terminate string	ld	hl,filebuf		;<2>	call	skipspa			;Skip over leading blanks in number	call	strcat2			;Append number to line 3	ld	hl,MEM7	call	strcat2	ld	hl,msgbuf		;Display line 3	call	ostring	ld	hl,MEM8	ld	de,msgbuf	call	strcpy			;Start summary line 4	ld	de,(HIGH$)	push	de	call	ohex16			;Add HIGH$ to working buffer	ld	hl,MEM9	call	strcat2	pop	de	ld	hl,0ffffh		;Compute amount of HIGH$ in use	or	a	sbc	hl,de			;HL = remains	ld	de,filebuf		;<2>DE buffer to play in	ldos	@hexdec			;Convert to decimal	ld	a,3	ld	(de),a			;Terminate string	ld	hl,filebuf		;<2>	call	skipspa			;Skip leading spaces	call	strcat2			;Add to the 4th line	ld	hl,MEM10	call	strcat2	ld	hl,msgbuf	call	ostring			;Display 4th line of summary	header	'Display information on disk drivers';	This section determines which drives are active and which are;	used by which driver.trydriver:	ld	a,(drivers)		;Do they want driver information?	or	a	jp	nz,trydevice		;No, skip to device section	ld	a,(prev)		;Did we display the memory summary?	or	a	jr	z,skp1			;No	ld	hl,EMPTYL		;Skip a line to separate memory	call	ostring			;summary from driver informationskp1:	ld	a,1			;Flag that we have output text	ld	(prev),a	ld	a,(titles)		;Should we display the titles?	or	a			;	jr	nz,notit1		;No	ld	hl,DRVT1		;Display titles 	call	ostring	ld	hl,DRVT2	call	ostring	ld	hl,DRVT3	call	ostringnotit1:	ld	ix,470h			;Point at start of DCTs	ld	bc,0nxtdrv:	ld	a,(ix+0)		;Get active inactive flag	cp	0c3h	jp	z,match			;Match on this value	call	drvtobit		;	or	b			;Keep track of drives that are	ld	b,a			;disabled	jr	rdnxt			;Go to next byte;	The driver is activematch:	ld	l,(ix+1)		;Get address of driver	ld	h,(ix+2)	call	lookup			;Look up this address	jr	z,f1			;Found it (in IY)	eject;	Here we did not find a drive that was listed.f1:	call	drvtobit		;Build a bit map	or	(iy+8)	ld	(iy+8),a		;Set and update drive select tablerdnxt:	ld	de,10			;Bump to next DCT	add	ix,de	inc	c	ld	a,c	cp	8	jr	nz,nxtdrv;	All drives have been identified.  Now pass two begins for display;	PASS 2;	First we locate a drive number that has not been processed	push	bc			;Save original "not used" drive info	ld	c,0			;Start hereotrlp:	push	bc	push	de	push	hl	ld	hl,corig	ld	de,ctmp	ld	bc,7	ldir				;Fill composing buffer with blanks	pop	hl	pop	de	pop	bc	call	drvtobit		;Get bit map	ld	d,a			;Save bit we key on	and	b	jp	nz,notused		;Not used	eject;	This drive has not been displayed, so locate the driver that;	operates it.	ld	iy,ourtable		;Point at the start of driverssearch1:ld	a,d	and	(iy+8)			;Does this driver run this drive	jr	nz,losxz		;This is the place	push	de	ld	de,STRSIZE	add	iy,de	pop	de	jr	search1			;Search to next drive;	Okay, now we mark these drives as "processed" and display them.losxz:	ld	a,b	or	(iy+8)	ld	b,a			;Mark these bits as done	push	bc			;Save it all;	Now we display the individual drives that are selected	ld	hl,ctmp	ld	c,0			;Start at drive 0nov0:	call	drvtobit		;Drive number to test for	and	(iy+8)			;Is this bit set (drive == driver)	jr	z,nov10			;No	ld	a,c	add	a,'0'			;Convert drive number to ASCII	ld	(hl),a			;Write drive number	inc	hl	inc	c			;Increment to next drive number	ld	a,c	cp	8	jr	z,dn2			;Done	call	drvtobit	and	(iy+8)	jr	z,nov11	ld	(hl),'-'		;We have detected a range of drive	inc	hl			;numbers that use the same driver	ld	a,c			;so display them using a - to save	add	a,'0'			;space.  Convert end drive # to ASCII	ld	(hl),a	inc	hl	ejectnov12:	inc	c			;Increment to next drive number	ld	a,c	cp	8	jr	z,dn2			;Done	call	drvtobit	and	(iy+8)	jr	z,nov11			;Go back to normal drive search	dec	hl			;Next higher drive is also using	ld	a,c			;same drive, range continues.	add	a,'0'			;Convert new drive # to ASCII	ld	(hl),a			;and write it over the last one.	inc	hl	jr	nov12			;Now repeat for next higher drive #nov11:	ld	(hl),','		;Here we found a second drive using	inc	hl			;the same driver, but not contiguous					;drive numbers.  Use a comma.nov10:	inc	c			;Increment to next drive number	ld	a,c	cp	8	jr	z,dn1			;All done?	jr	nov0			;Search for another driver.;	Display information regarding this driverdn1:	dec	hl	ld	(hl),' '		;Wipe trailing commadn2:	ld	hl,ctmp	ld	de,msgbuf	call	strcpy			;Copy composed drives to line buffer	call	stats			;Get driver details and display line;	Okay, go on to next outer loop	pop	bcnotused:inc	c			;Increment to next drive	ld	a,c			;Repeat until all drives have been	cp	8			;identified and count is exhausted.	jp	nz,otrlp		;Advance to next loop	header	'Locate information on drivers for character devices';	This section determines which drivers are used by the various;	character devices and displays them.trydevice:	ld	a,(devices)		;<3>Should we display device info?	or	a			;<3>	jp	nz,other		;<3>No, try "Other" section.	ld	a,(prev)		;Did we display memory or drive info?	or	a	jr	z,skp2			;No	ld	hl,EMPTYL		;Yes, so skip a blank line	call	ostringskp2:	ld	a,1			;Flag that we output text here	ld	(prev),a	ld	a,(titles)		;Should we display titles?	or	a			;	jr	nz,notit2		;No.	ld	hl,CHRT1		;Display  Device section titles	call	ostring			;<3>	ld	hl,CHRT2	call	ostring	ld	hl,CHRT3	call	ostringnotit2:	ld	ix,dcbtbl		;Our table for gathered information	ld	iy,208h			;Point at start of device table	ld	b,MAXDCB		;MAX possible number of DCBs	ld	c,0dcblp:	ld	a,(iy+0)		;Is this DCB in use?	or	a	jr	nz,adddcb		;Yesdcbxlp:	push	iy			;Advance to next DCB slot	pop	hl	ld	de,8	add	hl,de	push	hl	pop	iy	djnz	dcblp			;Loop until all slots examined	jr	dosort			;Start sort of DCBs that were found	ejectadddcb:	ld	(ix),a			;Copy DCB information into our table	ld	h,(iy+6)	ld	(ix+1),h	ld	l,(iy+7)	ld	(ix+2),l		ld	h,(iy+1)	ld	(ix+3),h	ld	l,(iy+2)	ld	(ix+4),l	inc	c			;Increment count of DCBs found	push	ix			;Advance pointer into our table	pop	hl	ld	de,DCBSTRSZ	add	hl,de	push	hl	pop	ix	jr	dcbxlp			;Advance pointer in DCB memory;	We have all DCB entries in our table, now do a sort.;	This bubble sort is not very efficient, but for small numbers of;	items this is not a problem.  A better sort algorithm can be found;	in FILESORT/SRC, used by several applications.dosort:	ld	ix,dcbtbl		;Point at start of our table	ld	b,c			;Get number of entries	dec	b			;Sort n-1 pairs	ld	d,0			;Reset SWAP flagsortnxt:ld	a,(ix+1+DCBSTRSZ)	;First character	cp	(ix+1)	jr	c,sortb	jr	nz,noswap		;Already in right order	ld	a,(ix+2+DCBSTRSZ)	cp	(ix+2)	jr	nc,noswap		;Already in correct ordersortb:	ld	d,1			;We performed at least one swap	ld	a,(ix+1+DCBSTRSZ)	;Exchange all elements of pair	ld	e,(ix+1)	ld	(ix+1+DCBSTRSZ),e	ld	(ix+1),a	ld	a,(ix)	ld	e,(ix+DCBSTRSZ)	ld	(ix+DCBSTRSZ),a	ld	(ix),e	eject	ld	a,(ix+2)	ld	e,(ix+2+DCBSTRSZ)	ld	(ix+2+DCBSTRSZ),a	ld	(ix+2),e	ld	a,(ix+3)	ld	e,(ix+3+DCBSTRSZ)	ld	(ix+3+DCBSTRSZ),a	ld	(ix+3),e	ld	a,(ix+4)	ld	e,(ix+4+DCBSTRSZ)	ld	(ix+4+DCBSTRSZ),a	ld	(ix+4),enoswap:	push	ix			;Advance pointer to next pair	pop	hl			;(This includes second item of last	push	de			; pair)	ld	de,DCBSTRSZ	add	hl,de	pop	de	push	hl	pop	ix	djnz	sortnxt			;Repeat until all pairs tested	ld	a,d			;Did any pairs exchange positions?	or	a	jr	nz,dosort		;Then repeat all comparisons	header	'Display character device information';	Okay, the table is now sorted.  Now locate each driver by address;	and then display the information for that device.;	DCB's that have no associated driver	ld	ix,dcbtbl		;Point at our sorted tabledcbnxt3:ld	a,(ix)			;When we find an empty entry,	or	a			;we have found the end of the table	jr	z,other	ld	e,(ix+3)	ld	d,(ix+4)	ld	iy,ourtable		;Point at table of memory modules					;previously located.dcbnxt1:ld	l,(iy)	ld	h,(iy+1)	ld	a,h	or	l	jr	z,dcbnxt2		;End of our table, no memory module!	or	a	sbc	hl,de	jr	z,dcbmat		;Match on a DCB - module located	push	iy			;Did not compare, look at next	pop	hl			;memory module until one with	ld	bc,STRSIZE		;same address is located.	add	hl,bc	push	hl	pop	iy	jr	dcbnxt1			;Test next ourtable entry;	We have located the DCB, so display itdcbmat:	ld	de,msgbuf	ld	a,'*'	call	strcatb			;Start Device line with a '*'	ld	a,(ix+1)	call	strcatb2		;Copy device ID characters	ld	a,(ix+2)	call	strcatb2	ld	hl,DCBTAB	call	strcat2			;A title string	ld	(iy+8),080h		;Flag as used (displayed)	call	stats			;Get module details and display it;	Here we did or did not find the module for this device.;	Skip to the next one.dcbnxt2:push	ix	pop	hl	ld	de,DCBSTRSZ	add	hl,de	push	hl	pop	ix	jr	dcbnxt3			;Do next device found in DCB table	header	'Display modules that are not direct character/disk drivers';	This section shows modules that were not identified as character;	or disk drivers.  These could be a patch, such as the Houde patches,;	or it could be a piece of driver code that is shared, such as the;	Powersoft disk drivers or the DiskDisk support module.other:	ld	a,(devices)		;<3>Other is only display with full	ld	b,a			;<3>device/driver display	ld	a,(drivers)	or	b	jp	nz,end1	ld	a,(prev)	or	a	jr	z,skp3	ld	hl,EMPTYL	call	ostringskp3:	ld	a,1			;Set output flag in case more sections	ld	(prev),a		;are added one day.	ld	a,(titles)		;	or	a			;	jr	nz,notit3		;	ld	hl,OTHT1		;<3>Title	call	ostring			;<3>	ld	hl,OTHT2	call	ostringnotit3:	ld	iy,ourtabledrslp:	ld	a,(iy)	or	(iy+1)	jp	z,end1	ld	a,(iy+8)		;Was this displayed as a drive	or	a	jr	z,drsn			;Not reported yet.drsnxt:	push	iy	pop	de	ld	hl,STRSIZE	add	hl,de	push	hl	pop	iy	jr	drslp;	Here we have a module that needs to be mentioned.drsn:	ld	hl,corig		;'       ' Enough spaces to reach	ld	de,msgbuf		;the second column	call	strcpy			;Since we don't know who owns it, just	call	stats			;display start, stop and length	jr	drsnxt	header	'Display the address and size of a memory module'stats:	ld	hl,ADDR1		;'0x'	call	strcat2	ld	e,(iy+0)	ld	d,(iy+1)	call	ohex16			;Convert starting address	ld	hl,ADDR2		;' - 0x'	call	strcat2	ld	e,(iy+2)	ld	d,(iy+3)	call	ohex16			;Convert ending address	ld	hl,ADDR4		;'  '	call	strcat2	ld	e,(iy+4)		;Get size of module	ld	d,(iy+5)	ld	a,(decimal)		;Are we to provide that in decimal?	or	a	jr	z,hex1			;No, hex will do	ld	hl,ADDR5		;' ' (makes columns come out right)	call	strcat2	ld	hl,ourbuf	ex	de,hl	ldos	@hexdec			;Convert to decimal	ld	a,03h	ld	hl,ourbuf	call	strcat2			;Add to the ASCII value to the line	jr	vcom1hex1:	ld	hl,ADDR3		;'0x'	call	strcat2	call	ohex16			;Display size in hexvcom1:	ld	hl,ADDR4		;'   '	call	strcat2	push	iy	pop	hl	ld	de,10	add	hl,de			;Skip over values and point at module	push	hl			;name	ld	b,8			;Max size of 8 characters supportedstrl1:	ld	a,(hl)			;Read a byte	cp	03h			;End of string yet?	jr	z,stre1			;Yes, all done	call	strcatb2		;No, Copy module ID a byte at a time	dec	b			;Keep track of size of this name	inc	hl			;Increment pointer	jr	strl1			;Do next character	ejectstre1:	ld	a,b			;Did we use all 8 columns?	or	a	jp	m,wrapit1		;Yes, so don't pad it outpad1:	ld	a,' '			;Pad short names to make columns	call	strcatb2		;line up	djnz	pad1wrapit1:pop	hl	call	expname			;Get name from table MAPMEM/INI	ld	a,0dh	call	strcatb2	ld	hl,msgbuf	call	ostring			;Display finished line	ret	header	'Display a description of the module based on the module name';	Attempt to find the long version of a nameexpname:push	ix	push	iy	push	bc	push	de	ld	iy,destblexpcnt:	push	iy	pop	de	ld	a,(de)	or	a	jr	z,exitlp	push	hlnextbt:	ld	a,(de)	cp	(hl)	jr	nz,nom1			;Miscompare, go to next	cp	3	jr	z,goodm			;Good match	inc	de	inc	hl	jr	nextbtnom1:	ld	de,LENOFF	add	iy,de	pop	hl	jr	expcntgoodm:	pop	hl	ld	a,' '	call	strcatb2	ld	a,'('	call	strcatb2	ld	de,IDMAX	add	iy,de	push	iy	pop	hl	call	strcat2	ld	a,')'	call	strcatb2exitlp:	pop	de	pop	bc	pop	iy	pop	ix	ret	header	'Search for memory modules in high or low memory';	This routine searches starting at IY for drivers or modules;	and stops when IY = limit;	Each driver located is added to our internal tables IXsearch:	push	iy	pop	de	ld	hl,(limit)	or	a	sbc	hl,de	ret	z			;End of search	ld	a,(modcnt)	inc	a	ld	(modcnt),a	ex	de,hl			;Move starting point to hl	ld	(ix),l			;LSB address	ld	(ix+1),h		ld	e,(iy+2)		;Get end address	ld	d,(iy+3)	ld	(ix+2),e	ld	(ix+3),d	ex	de,hl	or	a	sbc	hl,de	inc	hl			;Adjust for zero-based math	ld	(ix+4),l		;Store length of driver	ld	(ix+5),h;	Pick up pointer and length of string	ld	c,(iy+4)		;Get Number of characters	push	iy	pop	hl	ld	de,5	add	hl,de	push	hl			;Save it for a moment	push	ix	pop	hl	ld	de,10			;6	add	hl,de	ex	de,hl			;Move destination to de	pop	hl	ld	b,0	ldir				;Copy string	ld	a,3			;ETX	ld	(de),a			;Terminate the string	eject;	Bump our pointer to the next structure	push	ix	pop	hl	ld	de,STRSIZE		;Size of one of our structures	add	hl,de	push	hl	pop	ix	ld	l,(iy+2)	ld	h,(iy+3)	inc	hl	push	hl	pop	iy	jp	search			;Do next one	header	'Misc support routines';	Convert a 16 bit number into a 4 digit hex value and add it to the;	working buffer.ohex16:	ld	hl,(strptr)	ldos	@hex16	ld	(strptr),hl	ld	(hl),3	ret;	Read a byte from the string filegetbyte:push	hl	push	de	ld	hl,(fileptr)	ld	a,(byteptr)		;Get our position in the file	or	a			;Any more to read in this sector?	jr	nz,morebyt		;Yes	ld	hl,filebuf		;Here we need to read another sector	ld	de,filefcb	ldos	@read	jr	nz,rderr1		;Read failed, probably an EOF	ld	hl,(filefcb+10)		;Get number of records in file	ld	de,(filefcb+12)		;Get our position	xor	a	sbc	hl,de			;Are we at the last sector?	jr	nz,notend		;No, at least one more sector to go	ld	a,(filefcb+8)		;Yes, so find out how many bytes leftnotend:	ld	hl,filebuf		;Point at start of buffermorebyt:dec	a			;Decrement count	ld	(byteptr),a		;Store updated count	ld	a,(hl)			;Get a byte from the sector	inc	hl			;Increment buffer pointer	ld	(fileptr),hl		;Store pointer	cp	a			;Force Z flagrderr1:	pop	de			;Restore callers DE & HL	pop	hl	ret				;All done;	This converts a drive number into a bit valuedrvtobit:	push	bc			;Save callers BC	ld	b,c			;Get a copy of the drive select	inc	b			;Increment by 1	xor	a			;<2>Zero A	scf				;Set carry flagl1:	rla				;Shift bit left	djnz	l1			;Repeat specified number of times	pop	bc			;Restore callers BC	ret				;Done	eject;	Search our module table for a memory address that matcheslookup:	ex	de,hl			;Put in DE	ld	iy,ourtable		;Look in our tablelooknxt:ld	l,(iy+0)		;Get entry address	ld	h,(iy+1)	ld	a,l			;Is it 0x0000?	or	h	jr	z,badlook		;End of table reached	or	a	sbc	hl,de			;Subtract two entries	jr	z,gdlook		;They match (IY points to entry)	ex	de,hl			;Move test value to HL for a moment	ld	de,STRSIZE		;Size of entry in table	add	iy,de			;Advance pointer to next entry	ex	de,hl			;Put test value back in DE	jr	looknxt			;Look at next entrygdlook:	cp	a			;We found a match (see IY)	ret				;Z flag on successbadlook:or	1			;NZ on failure	ret	ifdef	LISTALL	else	;LISTALL	print	off	endif	;LISTALL	include	'DEFAULTS/SRC'	include	'MOREOUT/SRC'	include	'STRINGS/SRC'	include	'WILD/SRC'	ifdef	LISTALL	else	;LISTALL	print	on	endif	;LISTALL	header	'Read-Only Data for MAPMEM'MEM1:	defm	'Low Memory Driver/Module region begins at 0x'	defb	03MEM2:	defm	' and ends at 0x12FF.'	defb	0dhMEM3:	defm	'The low memory free region started at 0x'	defb	03MEM4:	defm	' at boot-time.'	defb	0dhMEM5:	defm	'Currently, the first free low memory location is at 0x'	defb	03MEM6:	defm	' with '	defb	03MEM7:	defm	' bytes free.'	defb	0dhMEM8:	defm	'High memory driver region begins at 0x'	defb	03MEM9:	defm	' and '	defb	03MEM10:	defm	' bytes are in use.'	defb	0dh;		 12345678901234567890123456789012345678901234567890;		          1         2         3         4         5;		5         6         7         8;		 0,1,2,3,4,5,6,7;		 0.2.4.6DRVT1:	defm	'Disk Drivers'	defb	0dhDRVT2:	defm	'Logical  Base     End     Length  Driver'	defm	'   (Description)'	defb	0dhDRVT3:	defm	'Drives                            Name'	defb	0dhCHRT1:	defm	'Character Devices and Filters'	defb	0dhCHRT2:	defm	'Logical  Base     End     Length  Driver'	defm	'   (Description)'	defb	0dhCHRT3:	defm	'Name                              Name'	defb	0dhDCBTAB:	defm	'  'ADDR4:	defm	' 'ADDR5:	defm	' '	defb	03ADDR1:	defm	'  0x'	defb	03ADDR2:	defm	' - 0x'	defb	03ADDR3:	defm	'0x'	defb	03	ejectOTHT1:	defm	'Other modules (shared drivers, patches, etc.)'	defb	0dhOTHT2:	defm	'         Base     End     Length  Driver'	defm	'   (Description)'	defb	0dhWARN1:	defm	'?Low memory allocation chains are corrupted.  Displayed'	defb	0dhWARN11:	defm	' information may not be valid.'	defb	0dhWARN2:	defm	'?High memory allocation chains are corrupted.  Displayed'	defb	0dhWARN21:	defm	' information may not be valid.'	defb	0dhRDERR:	defm	'%Can''t read BOOT/SYS - some information will be incorrect.'	defb	0dhBOPTMSG:defm	'?Usage:  mapmem [-demprst!?h] [>[>] file|device]'	defm	' [;next command]'	defb	0ah	defm	'Options:  (? or h displays this message)'	defb	0ah	defm	'-d   Display sizes in decimal'	defb	0ah	defm	'-e   Display device drivers only'	defb	0ah	defm	'-m or -s'	defb	0ah	defm	'     Display the summary only'	defb	0ah	defm	'-r   Display disk driver information only'	defb	0ah	defm	'-t   Omit headers'	defb	0ah	defm	'-p   Pause long displays using --More--'EMPTYL:	defb	0dhSYN1:	defm	'?Format error in description file on line'	defb	03SYN2:	defm	'.'	defb	0dhNOMORE:	defb	10h	defm	'--No More--'	defb	11h,1fh,03hPATCH:	defb	128%0			;Used for field patches	header	'Read/Write Data for MAPMEM'defptr:	defw	0			;Used by DEFAULTSfilebuf:				;Share buffer with defaultsdefbuf:	defb	128%0			;Used by DEFAULTS	defb	128%0			;Buffer can be used by later ops;		 123456789012345;		 0,1,2,3,4,5,6,7;		 0,2,4,6corig:	defm	'       '	defb	03ctmp:	defm	'       '	defb	03limit:	defw	0modcnt:	defb	0decimal:defb	0summary:defb	0devices:defb	0drivers:defb	0nxtcmd:	defw	0			;inoption:defw	0			;titles:	defb	0			;prev:	defb	0cmdbuf:	defs	80ourbuf:	defb	85%0	ejectdecbuf:	defb	6%0filefcb:defm	'MAPMEM/INI'	defb	03	defb	22%0fileptr:defw	0byteptr:defb	0lincnt:	defw	0nxtptr:	defw	0;	As we find modules in low or high memory, they are added to this;	table.ourtable:defw	DRVCNT%0		;+0 Start address of drive (word)					;  (is zero if the entry is empty)	defw	DRVCNT%0		;+2 End Address of driver (word)	defw	DRVCNT%0		;+4 Length of driver (word)	defw	DRVCNT%0		;+6 Device information (word)	defw	DRVCNT%0		;+8 Drivers information (word)	defb	4*DRVCNT%0		;+10 Driver name string (20 bytes)	defb	4*DRVCNT%0		;+14 ...	defb	4*DRVCNT%0		;+18 ...	defb	4*DRVCNT%0		;+22 ...	defb	4*DRVCNT%0		;+26 ...	defb	2*DRVCNT%0		;+30 Spare word					;+32;	This table is used to hold DCB entries that point into ourtable.;	This table will be sorted to provide an orderly display.dcbtbl:	defb	DCBSTRSZ*MAXDCB%0	;Storage for DCBsdestbl:	defs	NUMDES*LENOFF		;Module name strings go herelastbyt:equ	$	end	begin