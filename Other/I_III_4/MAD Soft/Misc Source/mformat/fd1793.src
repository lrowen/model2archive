;	Equates for the Western Digital FD179X-02 / FD1773;	Copyright 1991, M. A. D. Software, All Rights Reserved;	Type I Commands					7  6  5  4  3  2  1  0RESTORE:	equ	00h		;Restore	0  0  0  0  h  V r1 r0SEEK:		equ	10h		;Seek		0  0  0  1  h  V r1 r0STEPIN:		equ	40h		;Step In	0  1  0  T  h  V r1 r0STEPOUT:	equ	60h		;Step Out	0  1  1  T  h  V r1 r0;	Type II CommandsREAD:		equ	80h		;Read Sector	1  0  0  m  S  E  C  0WRITE:		equ	0a0h		;Write Sector	1  0  1  m  S  E  C a0;	Type III CommandsREADADDR:	equ	0c0h		;Read Address	1  1  0  0  0  E  0  0READTRK:	equ	0e0h		;Read Track	1  1  1  0  0  E  0  0WRITETRK:	equ	0f0h		;Write Track	1  1  1  1  0  E  0  0;	Type IV CommandsFORCEINT:	equ	0d0h		;Force Interrupt1  1  0  1 I3 I2 I1 I0;	Control flags for Type I CommandsSTEP6:		equ	0		; 6 Msec Step	x  x  x  x  x  x  0  0STEP12:		equ	1		;12 Msec Step	x  x  x  x  x  x  0  1STEP20:		equ	2		;20 Msec Step	x  x  x  x  x  x  1  0STEP30:		equ	3		;30 Msec Step	x  x  x  x  x  x  1  1VERIFY:		equ	4		;Verify Flag	x  x  x  x  x  1  x  xHEADLOAD:	equ	8		;Head Load Flag x  x  x  x  1  x  x  xTRACKUPD:	equ	10h		;Track Update	x  x  x  1  x  x  x  x;	Control flags for Type II & III CommandsDAM:		equ	1		;Data Addr Mark	x  x  x  x  x  x  x  1COMPARE:	equ	2		;Side Compare	x  x  x  x  x  x  1  xDELAY15:	equ	4		;15 Msec Delay	x  x  x  x  x  1  x  xSIDE1:		equ	8		;Select Side 1	x  x  x  x  1  x  x  xMULTI:		equ	10h		;Multi Sector	x  x  x  1  x  x  x  x;	Control flags for Type IV CommandsNR_TO_RDY:	equ	1		;Not Ready to Ready TransitionRDY_TO_NR:	equ	2		;Ready to Not Ready TransitionEACH_INDEX:	equ	4		;Every Index PulseIMMEDIATE:	equ	8		;Immediate InterruptTERMINATE:	equ	0		;Terminate current command;	Type I StatusNOT_READY:	equ	80h		;Not ReadyWP:		equ	40h		;Write ProtectedHL:		equ	20h		;Head LoadedSEEK_ERR:	equ	10h		;Seek ErrorCRC_ERR:	equ	8h		;CRC ErrorTRACK_0:	equ	4h		;Track 0INDEX:		equ	2h		;Index PulseBUSY:		equ	1h		;FDC Busy;	Type II & III StatusSEC_TYPE:	equ	20h		;1 = Deletes Data Mark, 0 = Data MarkWRITE_FAULT:	equ	20h		;1 = Write FaultSEC_NF:		equ	10h		;Track, Sector or Side not foundLOST_DATA:	equ	4h		;Lost Data ErrorDRQ:		equ	2h		;FDC data xfer ready