	title	'MFORMAT - Fast format system'	print	short,nomac;	print off;	Mformat - Fast format system;	Copyright 1981, 1990, 1991, 1992, M. A. D.  Software.;	All Rights Reserved.;	This program formats a disk in the LS-DOS/LDOS or TRSDOS 1.x formats.	psect	6000h	ref	'TRSDOS6/SRC'	ref	'FD1793/SRC'FDC_DATA:	equ	0f3h		;Data PortFDC_SECTOR:	equ	0f2h		;Sector PortFDC_TRACK:	equ	0f1h		;TrackFDC_CMD:	equ	0f0h		;CommandFDC_STATUS:	equ	0f0h		;StatusFDC_SELECT:	equ	0f4h		;SelectWRNMI:		equ	0e4h		;NMI ControlDRIVE_0:	equ	1		;Drive 0DRIVE_1:	equ	2		;Drive 1DRIVE_2:	equ	4		;Drive 2DRIVE_3:	equ	8		;Drive 3SIDE_ONE:	equ	10h		;Side 1 SelectPRECOMP:	equ	20h		;Write Precompensation EnabledIO_WAIT:	equ	40h		;CPU WaitsFDC_MFM:	equ	80h		;MFM = 1, FM = 0ERR_CRC:	equ	1		;CRC ErrorERR_SEEK:	equ	2		;Seek ErrorERR_LOST:	equ	3		;Lost data errorERR_NF:		equ	4		;Id not foundERR_NR:		equ	5		;Drive not readyERR_NA:		equ	6		;No driveERR_DOOR:	equ	7		;Door open?TRK_UNK:	equ	0		;Track type unknownTRK_MFM:	equ	1		;Track is MFMTRK_FM:		equ	2		;Track is FMTRK_SPLIT:	equ	3		;Track is split densitySIZE128:	equ	0		;Size from Read Address CommandSIZE256:	equ	1SIZE512:	equ	2SIZE1024:	equ	3NOFORMAT:	equ	0ISFORM:		equ	1IS512MFM:	equ	2IS128FM:	equ	3IS250MFM:	equ	4ldos:	macro	#1	ld	a,#1	rst	28h	endmhello:	defm	'MFormat - Diskette formatter   '	defm	'Version  1(1)  31-Jan-92   '	defb	0ah	defm	'PROTOTYPE VERSION - NOT FOR DISTRIBUTION'	defb	0ah	defm	'Copyright 1992, M. A. D.  Software.  '	defm	'All Rights Reserved.'	defb	0ah,0dhbegin:	ld	de,ourbuf		;Make copy of system command buf	ld	bc,82	ldir	ld	hl,ourbuf		;Use our buf from now onparnxt:	ld	a,(hl)			;Pick up character	cp	' '			;Space?	jr	nz,parnsp		;No	xor	a	ld	(inoption),a		;Not an option anymore	inc	hl	jr	parnxt			;Skipparnsp:	cp	0dh			;End?	jp	z,parend		;End of parms to parse	cp	'-'			;Option switch	jr	z,paropt		;Handle option	cp	':'			;Is it a drive spec?	jp	z,pardrv		;Handle drive	cp	'0'			;Drive number?	jr	c,ndr			;No	cp	'9'+1	jp	c,pardrv2ndr:	cp	'>'			;Redirection?	jp	z,parred		;Handle redirection	cp	';'			;Start of next command?	jp	z,parcmd		;Handle for next command	ld	b,a			;Save character	ld	a,(inoption)		;Did we process an option last?	or	a	jp	z,badopt		;Terminate processing	ld	a,b			;Perhaps it is a -abc option.	jr	opt2			;Get next character	eject;	Parse option switches and parametersparopt	ld	a,(redirect)		;Have we found a redirection yet?	or	a	jp	nz,badopt		;If so, too late for options	inc	hl			;Bump past '-'	ld	a,(hl)			;Get option code	ld	(inoption),a		;Remember we were hereopt2:	or	20h			;Fold case	cp	'a'			;Report on file allocation	jr	z,goa	cp	't'			;Report on media type	jr	z,got	cp	'd'			;Display lengths in Decimal	jp	nz,badopt;	-d  -  Display Length in Decimalsgod:	inc	hl			;Bump beyond flag	ld	(decimal),a		;Set non-zero	jr	parnxt			;Move to next item;	-a  -  Report on allocationgoa:	inc	hl	ld	(alloc),a	jp	parnxt;	-t  -	Report on media typegot:	inc	hl	ld	(type),a	jp	parnxt;	Parse drive numberpardrv:	inc	hl	ld	a,(hl)	cp	' '	jr	z,pardrv	cp	0dh	jr	z,badopt	cp	'0'	jr	c,badopt	cp	'9'+1	jr	nc,badoptpardrv2:sub	'0'	ld	(drive),a	inc	hl	jp	parnxt	eject;	Handle > redirectparred:	ld	de,logname	ld	(redirect),a	inc	hl	call	skipspa	cp	0dh	jr	z,badoptdonxt:	ld	(de),a	inc	hl	inc	de	ld	a,(hl)	cp	0dh	jr	z,parend	cp	' '	jp	z,parnxt	cp	';'	jp	z,parnxt	jr	donxtbadopt:	ld	hl,BOPTMSGerrabt:	ldos	@dsply	ldos	@abortskipspa:ld	a,(hl)	cp	' '	ret	nz	inc	hl	jr	skipspaparcmd:	inc	hl	call	skipspa	cp	0dh	jr	z,parend	ld	(nxtcmd),hlparend:	push	hl			;Save entry command	ld	a,(redirect)	or	a	jr	z,noopen	ld	de,logfcb	ld	hl,logname	ldos	@fspec	ld	hl,M18	jr	nz,errabt	ld	b,0	ld	hl,logname	ldos	@init	ld	hl,M19	jr	z,noopen	cp	2ah			;This error is ok	jr	nz,errabt	ejectnoopen:	ld	hl,hello	call	ostring;	First, convert logical drive into physical drive.	ld	a,(drive)	cp	0ffh	jr	z,badopt	ld	c,a	ldos	@gtdct		ld	a,(iy+3)		;Get drive type	bit	3,a;	jp	nz,harddisk		;No need doing a media scan;	Okay, it's a floppy	xor	a			;Set cyl to 0 (will be there on exit)	ld	(iy+5),a		;Do it	ld	a,(iy+4)	and	0fh	ld	(select),a		;Save drive select here;	Okay, first thing is to try to determine the media type.;	We will start with the assumption that we have a MFM floppy.	or	FDC_MFM	out	(FDC_SELECT),a		;Select side 2 (gives us 2 or 3 secs)	ld	(sdh),a			;Save current state	call	restoreid		;Do the special restore	cp	0	jr	z,media_go		;Media is ready and MFM	cp	ERR_CRC	jr	z,media_go		;CRC Error but media is ready	cp	ERR_SEEK	jr	z,media_go		;Seek Error but media is ready;	Here the media is not ready	call	hltfdc			;Make sure controller resets	ld	hl,NRMSG	jp	errabt			;Abort;	Here the drive does have some sort of media.  We now try to;	figure out what the format type is on track 0 (FM or MFM).media_go:;	for now, assume MFM	ld	hl,trackbuf	ld	de,mfmpattern	ld	b,18nextsec:push	bc	call	buildtrk	pop	bc	djnz	nextsec;	The track has now been constructed.  We will fill the sector;	and cylinder info in on the fly as we go.;	This code constructs the interleave table.  	ld	a,0			;Starting sector (Skew)	ld	b,18			;Max sectors (1 based)	ld	c,2			;Interleave	ld	d,0			;Base sector number	push	af	ld	a,d	ld	(ibase),a	pop	af	ld	e,b	ld	d,0	ld	hl,intl	add	hl,de	ld	(ilimit),hl	ld	e,c	ld	d,0	ld	hl,intliloop:	ld	(hl),a	inc	a	cp	b	jr	nz,ibump	ld	a,(ibase)		;Reset to starting valueibump:	add	hl,de	push	de	push	hl	ld	de,(ilimit)	or	a	sbc	hl,de	jr	c,inext;	Handle roll-over	ld	de,intl+1	add	hl,de	pop	de	pop	de	jr	icominext:	pop	hl	pop	deicom:	djnz	iloop;	Let's start writing	ld	a,0	ld	(sides),a	ld	hl,0	ld	(cylside),hl	ld	a,(select)	or	FDC_MFM	ld	(sdh),a	out	(FDC_SELECT),a	ld	c,FDC_STATUS	ld	b,5			;5 Revolutions to assure speed-upnoindex	in	d,(c)	bit	1,d	out	(FDC_SELECT),a		;Keep drive going	jr	z,noindexyesindex:in	d,(c)	bit	1,d	out	(FDC_SELECT),a	jr	nz,yesindex	djnz	noindex	ld	de,(cylside)	ld	bc,12fbh		;18 sectors, DAM	call	stuffmfmtrknxt:	ld	hl,trackbuf	ld	c,WRITETRK		;+DELAY15	ld	a,(sdh)	ld	d,a	call	dowrite	ldos	@abort	ld	de,(cylside)	ld	a,(sides)	or	a	jr	z,oneside	cp	e	jr	z,oneside	inc	e	jr	othersideoneside:ld	e,0	inc	d			;Bump cylinder	ld	a,40	cp	d	jr	z,doneotherside:	ld	(cylside),de	ld	bc,12fbh	call	stuffmfm	ld	de,(cylside)	ld	a,e	add	a,0fh	and	10h	ld	b,a	ld	a,d	cp	20			;Start precomp?	jr	c,nopre	set	5,bnopre:	ld	a,(select)	or	FDC_MFM	or	b	ld	(sdh),a	out	(FDC_SELECT),a	ld	a,e	or	e	jr	nz,trknxt		;No step	ld	a,STEPIN	call	fboth	jr	trknxtdone:	ldos	@abort;	This code inserts the information into the raw trackstuffmfm:	ld	ix,intl	ld	hl,trackbuf+mfmstart+mfmoffsetnexts:	ld	(hl),d			;Insert Cylinder	inc	hl	ld	(hl),e			;Insert Side	inc	hl	ld	a,(ix)			;Read Sector	inc	ix	ld	(hl),a			;Insert Sector	inc	hl	push	de	ld	de,mfmdoffset	add	hl,de	ld	(hl),c			;Write DAM	ld	de,mfmnsec		;Bump to next sector ID field	add	hl,de	pop	de	djnz	nexts	ret	;	ldos	@abort;	Build a track based on a design table;	Accepts;	HL = Target buffer, previous block +1;	DE = Control table;	Returns;	HL = Added Block +1;	DE = Points to start of "Next Sector" control block	buildtrk:	ld	a,(de)			;Get the control byte	inc	de			;Advance the pointer	inc	a			;Are we done?	jr	z,trkexit		;Exit if 0ffh detected	dec	a	jr	z,longsec		;Word insert	ld	b,a			;Make this the count	ld	a,(de)			;Get the character	inc	de			;Advance pointerfill1:	ld	(hl),a			;Write it to the target area	inc	hl			;next	djnz	fill1			;Loop till area is filled	jr	buildtrk		;Do next entrylongsec:ld	b,a			;Put zero in b	ld	a,(de)			;Get first byte of pattern	inc	de	ld	(hl),a			;Store it	inc	hl	ld	a,(de)			;get next byte	inc	de	ld	(hl),a			;Store second byte	push	de			;Save DE	ld	d,h	ld	e,l	inc	de			;Advance destination pointer	dec	hl			;Decrement source pointer	ld	bc,254			;Move this much	ldir				;Do it	ex	de,hl			;HL is now destination again	pop	de	jr	buildtrk		;Do next entrytrkexit:ld	a,(de)			;Get next byte	ld	c,a	inc	de	ld	a,(de)			;Get next byte	ld	d,a	ld	e,c			;Get LSB	ret	inc	hl;	Generic read - It will read until the command ends or we get an error.;	HL = Starting address to write;	C = Command;	E = Select;	All other FDC values must be loaded previously;	On return,;	A = error code (NZ) or no error (Z = 0);	DE = Number of bytes transferreddoread:	call	hltfdc	di	ld	ix,(0066h)		;Caution, overlapping reads	ld	iy,(0067h)	push	hl			;Save address	ld	hl,nmiser	ld	(0067h),hl	ld	a,0c3h	ld	(0066h),a	pop	hl			;Restore	push	hl			;Save base address	ld	a,c			;Get the read command	ld	c,FDC_DATA		;Point at Data Register	out	(FDC_CMD),a		;Read a sector;	Put NMI ACtivate after Read Command To prevent false NMI's	ld	a,80h			;[4-t] Set NMI for INTRQ	out	(WRNMI),a		;[11-t] Set it now	call	settle			;Wait for FDC to lock	ld	a,d			;Get select value	out	(FDC_SELECT),a		;Select drive.  This gives about  2 to					;3 seconds from this point for readwtdrq1:	in	a,(FDC_STATUS)		;Read the FDC status	bit	1,a			;Test bit	jp	nz,start		;Wait for DRQ to come on	rlca				;Is drive still ready?	jp	nc,wtdrq1		;Wait but allow drive to time out	jr	rlp1			;Yes, Error Detectedstart:	ini				;Read the first byte;	Here we read the sector	ld	a,d			;Get select value	or	40h			;Set Hardware Waitsgtnxt:	out	(FDC_SELECT),a		;Force a wait on each byte	ini				;Read a byte from port (c)	jr	gtnxt			;[12-t on jump] Get next byte	eject;	This loop will exit to nmiser on end-of-command signal from FDC;	This code is entered via the NMI Interruptnmiser:	pop	de			;Lose the place that called us.	xor	a			;Turn off NMI	out	(WRNMI),a		;Now	ld	(0067h),iy	ld	(0066h),ixrlp1:	in	a,(FDC_STATUS)		;[11-t] Read status register	ei	pop	de			;Get back base address	or	a	sbc	hl,de	ex	de,hl			;DE = Number of bytes transferred	ld	b,a			;Put a copy of the status here	call	retn			;Fix up interrupts	jp	errchk			;Test for any errors;	Generic write - Writes until the command ends or an error occurs;	HL = Starting address to read;	C = Command;	E = Select;	All other FDC values must be loaded previously;	On return,;	A = error code (NZ) or no error (Z = 0);	DE = Number of bytes transferreddowrite:call	hltfdc	di	ld	ix,(0066h)		;Caution, overlapping reads	ld	iy,(0067h)	push	hl			;Save address	ld	hl,nmiser2	ld	(0067h),hl	ld	a,0c3h	ld	(0066h),a	pop	hl			;Restore	push	hl			;Save base address	ld	a,c			;Get the read command	ld	c,FDC_DATA		;Point at Data Register	di	;------------------------------------------------------------	out	(FDC_CMD),a		;Read a sector;	Put NMI ACtivate after Write Command To prevent false NMI's	ld	a,80h			;[4-t] Set NMI for INTRQ	out	(WRNMI),a		;[11-t] Set it now	call	settle			;Wait for FDC to locksydly:	in	a,(FDC_STATUS)	and	76h	jr	z,sydly	outi				;Load first byte	set	6,d			;Set Hardware Waits	ld	a,d			;Get select value	out	(FDC_SELECT),a		;Select drive.  This gives about  2 to					;3 seconds from this point for readwtdrq2:	in	a,(FDC_STATUS)		;Read the FDC status	bit	1,a			;Test bit	jp	nz,start1		;Wait for DRQ to come on	rlca				;Is drive still ready?	jp	nc,wtdrq2		;Wait but allow drive to time out	jr	rlp2			;Yes, Error Detectedstart1:	outi				;Write the second byte;	Here we read the sector	ld	a,d			;Get select value;	or	40h			;Set Hardware Waitsgtnxt1:	out	(FDC_SELECT),a		;Force a wait on each byte	outi				;Write a byte to  port (c)	jr	gtnxt1			;[12-t on jump] Get next byte	eject;	This loop will exit to nmiser on end-of-command signal from FDC;	This code is entered via the NMI Interruptnmiser2:pop	de			;Lose the place that called us.	xor	a			;Turn off NMI	out	(WRNMI),a		;Now	ld	(0067h),iy	ld	(0066h),ixrlp2:	in	a,(FDC_STATUS)		;[11-t] Read status register	ei	;------------------------------------------------------------	pop	de			;Get back base address	or	a	sbc	hl,de	ex	de,hl			;DE = Number of bytes transferred	ld	b,a			;Put a copy of the status here	call	retn			;Fix up interrupts	jp	errchk			;Test for any errorsretn:	retn;	This routine takes 36 usec to call, execute and return;	which is enough for the controller to accept a command;	This value is greater than 32 usec for a force interrupt;	and 28 usec for valid data in all status register bits.;**	Apparently Tandy is buying really crummy FDC's and they need much;	more to work properly.hltfdc:	ld	a,0d0h			;Stop any activity on drive	out	(FDC_CMD),a		;Now	push	bc	ld	b,0	jr	setup			;FDC has a problem. Force Interrupt					;takes many times longer than WD					;manual sayssettle:	push	bc			;[11-t 2.75 usec]	ld	b,19			;[7-t 1.75 usec]setup:	djnz	setup			;[B<>0 13-t 3.25 usec]					;[B=0 8-t 2.0 usec]	pop	bc			;[10-t 2.5 usec]	ret				;[10-t 2.5 usec]	eject;	This routine calls settle and waitfboth:	out	(FDC_CMD),a		;Issue command we were given	call	settle			;Wait for command to sink in;	This routine wait for busy to drop or time to pass	ld	c,0			;Clear previous status bytewait:	in	a,(FDC_STATUS)		;Test busy status	bit	0,a			;Is command still in progress?	ret	z	bit	7,a			;How about, not ready?	ret	nz	ld	c,a			;Save previous status - used in	jr	wait			;stating what drive looks like	ejectochar:	push	bc	push	de	ld	a,(redirect)		;	or	a	jr	nz,rdir1		;Is a redirect	ld	a,(printer)		;	or	a			;	jr	z,nolpr1			;	ldos	@prt	jr	nz,timeonolpr1:	ldos	@dsp	pop	de	pop	bc	retrdir1:	ld	de,logfcb	ldos	@put	jr	z,popextfatal9:	pop	de	pop	bc	ld	hl,M17			;	ldos	@dsply	ld	de,logfcb	ldos	@close	ldos	@abortostring:push	bc	push	de	ld	a,(redirect)		;	or	a	jr	nz,rdir2		;Is a redirect	ld	a,(printer)		;	or	a			;	jr	z,nolpr			;	push	hlnextbyt1:	ld	c,(hl)	ld	a,c	cp	3	jr	z,dx1	ldos	@prt	jr	nz,timeo	inc	hl	ld	a,c	cp	0dh	jr	nz,nextbyt1dx1:	pop	hlnolpr:	ldos	@dsplypopext:	pop	de	pop	bc	ret	ejectrdir2:	ld	de,logfcbnextbyt2:	ld	c,(hl)	ld	a,c	cp	03	jr	z,rpop	ldos	@put	jr	nz,fatal9	ld	a,(hl)	inc	hl	cp	0dh	jr	nz,nextbyt2rpop:	pop	de	pop	bc	rettimeo:	ld	hl,M20	pop	de	pop	bc	jp	errabt	chkpause:	ld	a,(redirect)	or	a	ret	nz			;Pause does not work on redirect	ld	a,(printer)	or	a	ret	nz			;or printer	ldos	@flags	ld	a,(iy+10)	xor	2			;Flip polarity	bit	1,a	ret	nz;	Pause has been requestedpflush:	ldos	@kbd	jr	nz,pempty	cp	61h	jr	nz,pflushpempty:	ldos	@key	cp	80h	res	1,(iy+10)	ret	eject;	Restore is done with verify in all cases.  Since this disk must be;	readable to count, this is a valid test.restoreid:	ld	a,RESTORE+VERIFY+HEADLOAD	;Get a restore command	call	fboth			;Do a settle and a wait	ld	b,a			;Put status in B	and	0dfh			;Lose head load	cp	NOT_READY+BUSY		;Is drive not ready?	jr	nz,erch2		;Looks good, but test for seek					;error anyway;	This code does checking when the drive was not ready.;	It can tell the difference between a drive that is turned;	off and a drive that is powered on but not ready.;	The fancy tests are fooled by 3 1/2" drive status signals;	which are not the same as a 5 1/4" drive when not ready.;				A  C			A  C;	Empty 		5.25	81 27		3.50	81 65;	Open Door 	5.25	81 67		3.50	81 65;	Loaded Ready	5.25	74 67		3.50	74 67;	No Drive	5.25	81 21		3.50	81 21	ld	a,c			;Get previous status	and	09eh			;Lose write-protect, head load					;and busy	ld	d,ERR_NA		;Start with drive non-existant or					;powered off	jr	z,fres2			;Yes	ld	d,ERR_NR		;Try for drive not ready	cp	TRACK_0+INDEX		;Restore did occur, and index can					;be seen	jr	z,fres2			;Ok, drive is empty	ld	d,ERR_DOOR		;Ok, disk is in drive but door is openfres2:	ld	a,d	or	a			;Set nz	ret				;Return to caller	eject;	Here, the command was a seek and the seek checked for errorserch3:	ld	b,d			;Put error status in berch2:	ld	a,ERR_SEEK		;On a seek this would be a seek error	jr	erch1			;Enter error checkererrchk:	ld	a,ERR_LOST		;Test for lost data on read	bit	2,b			;Well?	jr	nz,fres21		;Drives too fast, code too slow					;Also what we can see on higher					;density disks	ld	a,ERR_NF		;On a read this would be a ID errorerch1:	bit	4,b			;Was it Record Not Found/Seek Error?	jr	nz,fres21	ld	a,ERR_CRC		;Try for CRC Error	bit	3,b			;Was it a CRC Error	jr	nz,fres21	ld	a,ERR_NR		;Force Drive not ready	bit	7,b			;Is the drive not ready?	jr	nz,fres21	xor	a			;Everything must have worked	ret				;Return sucessfullyfres21:	or	a	ret	eject	print	short;	General Control MessagesM17:	defm	'?Error while writing to redirected file'	defb	0dhM18:	defm	'?Invalid filename specified'	defb	0dhM19:	defm	'?Cannot open filename specified'	defb	0dhM20:	defm	'?Error while writing to the printer'	defb	0dhNRMSG:	defm	'?Disk drive is not ready or powered-on.'	defb	0dhBOPTMSG:defm	'?Usage:  mformat [:]d [-c nn] [-h|s n] [-n diskname] [-q]'	defb	0dhmfmstart:	equ	32mfmoffset:	equ	12+3+1mfmdoffset:	equ	1+1+22+12+3mfmnsec:	equ	1+256+1+17+12+3+1mfmpattern:	defb	32,4eh		;Index A and Gap IA (Post Index)mfmnext:	defb	12,00		;Index Gap IB/IIIB (PLL Sync)		defb	3,0f5h		;Preset CRC (Write A1)		defb	1,0feh		;ID Address Mark		defb	3,0		;Space for					;Cylinder Number					;Side Number					;Sector Number		defb	1,01h		;Sector Length		defb	1,0f7h		;Write CRC		defb	22,04eh		;Gap IIA		defb	12,00h		;Gap IIB (PLL Sync)		defb	3,0f5h		;Preset CRC (Write A1)		defb	1,0fbh		;Data Address Mark		defb	0,06dh,0b6h	;256 bytes of data area		defb	1,0f7h		;Write CRC;		defb	24,04eh		;Gap IIIa		defb	17,04eh		;Gap IIIa as used by LS-DOS/TRSDOS		defb	0ffh		;End of table		defw	mfmnext		;Where to start for next sectorfmstart:	equ	40fmoffset:	equ	6+1		;Start of sector IDfmdoffset:	equ	fmoffset+4+1+1+11+6	;Start of DAM Markfmpattern:	defb	40,0ffh		;Index A and Gap IA (Post Index)fmnext:		defb	6,00h		;Index Gap IB/III (PLL Sync)		defb	1,0feh		;ID Address Mark		defb	4,0		;Space for					;Cylinder Number					;Side Number					;Sector Number		defb	1,02h		;Sector Length		defb	1,0f7h		;Write CRC		defb	11,0ffh		;Gap IIA		defb	6,00h		;Gap IIB (PLL Sync)		defb	1,0fbh		;Data Address Mark		defb	0,0e5h,0e5h	;256 bytes of data area		defb	1,0f7h		;Write CRC		defb	27,0ffh		;Gap IIIa		defb	0ffh		;End of table		defw	fmnext		;Pattern for next sectorlogfcb:		defb	32%0logname:	defb	128%0		;Hold name and put data		defb	128%0rdsize:		defw	0trktype:	defb	0trksize:	defb	0ourbuf:		defb	85%0grannum:	defw	0maxfiles:	defb	0granules:	defb	0inoption:	defb	0redirect:	defb	0alloc:		defb	0type:		defb	0printer:	defb	0drive:		defb	0decimal:	defb	0nxtcmd:		defw	0cylside:	defw	0sides:		defb	0sep:		defb	'/'sectors:	defb	0fail:		defb	0select:		defb	0sdh:		defb	0cyls:		defb	0sgran:		defb	0mcyls:		defw	0ccyl:		defw	0numbuf		defb	10%0ilimit:		defw	0ibase:		defb	0intl:		defb	28%0		;Largest known sector count + 1SECBUFSIZ:	equ	1024tmpbuf1:	defs	SECBUFSIZtmpbuf2:	defs	SECBUFSIZTRACKBUFSIZ:	equ	8192trackbuf:	defs	TRACKBUFSIZ	end	begin