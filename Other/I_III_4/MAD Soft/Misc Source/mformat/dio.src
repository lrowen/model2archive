floppy:	equ	1	;Floppy driver;	B	The following commands are available for both devices:read:	equ	12	;Read Sectorseek:	equ	6	;Seekrestore:equ	4	;Restoreinit:	equ	1	;Initialize Controller			;HDC Onlyrinit:	equ	50	;Force all drives to cylinder 0;	Floppy Disk Port Equatesf_stat:	equ	0f0h		;Command/Status Registerf_cmd:	equ	0f0h		;Command/Status Registerf_cyl:	equ	0f1h		;Cylinder Registerf_sect:	equ	0f2h		;Sector Registerf_data:	equ	0f3h		;Data Registerf_slct:	equ	0f4h		;Drive Select Register;	Floppy Disk Command Equatesf_step:	equ	0h		;Step rate 6msec  Flunk the crummy drives!f_rest:	equ	0ch+f_step	;Restore drive with head loaded				;and verify setf_seek:	equ	1ch+f_step	;Seek with verify and head loadedf_read:	equ	82h		;Read Sector, must be on side 0;	Floppy Disk Status Equatesf_nrdy:	equ	80h		;Not Readyf_wp:	equ	40h		;Drive Write Protectedf_load:	equ	20h		;Head Loadedf_sker:	equ	10h		;Seek Errorf_crc:	equ	8h		;CRC Errorf_trk0:	equ	4h		;Track 0 Detectf_indx:	equ	2h		;Index Pulse Detectf_busy:	equ	1h		;FDC Busy;	Standard Disk I/O Entry off of RST 8 comes heredisk:	dec	a		;Test for Floppy	jp	z,flopdvr	;Enter Floppy driver	header	'Flopdvr	Floppy Disk Driver	21-Aug-83 fdiv';	First, force FDC to stop any current activityflopdvr:call	hltfdc		;Halt the FDC;	First select the drive for either a restore or seek	ld	a,c		;Get the sector number (if any)	out	(f_sect),a	;Store that in the FDC;	Generate a SDH.  B = 0 for FM, and 0x80 for MFMmakesdh:ld	a,(drive)	;Get drive number	ld	c,1		;Starting drive mask	or	a		;Set up flagssdlp:	jr	z,sdex		;Mask in correct position	rl	c		;Shift mask left	dec	a		;Decrement drive #	jr	sdlp		;Loop till zerosdex:	ld	a,c		;Put mask here	or	b		;Merge density selection value	ld	(sdh_i),a	;Store for future use	out	(f_slct),a	;Do it	ret;	Now, determine if this is a restore, init or seek/read	ld	a,b		;Get the command	cp	restore+1	;Is it a restore?	jr	nc,fl3		;Seek or Read;	Any init commands will be treated as restores;Restore is done with verify in all cases.  Since this disk must be;readable to count, this is a valid test.	ld	a,f_rest	;Get a restore command	eject;Now, 12usec (MFM) or 6usec (FM) must be burned before looking at;the status register. [FD179X-02 p.188 (1983)];Times are doubled for 1mhz.  Model 4 is at 1mhz.	call	fboth		;Do a settle and a wait	ld	b,a		;Put status in B	and	0dfh		;Lose head load	cp	f_nrdy+f_busy	;Is drive not ready?	jr	nz,erch2	;Looks good, but test for seek error anyway;	This code does state checking using the results of the restore;	command.  It can tell the difference between a drive that is turned;	off and a drive that is powered on but not ready.	ld	a,c		;Get previous status	and	09eh		;Lose write-protect, head load and busy	ld	d,FDNA		;Start with drive non-existant or powered off	jr	z,fres2		;Yes	ld	d,FDNR		;Try for drive not ready	cp	f_trk0+f_indx	;Restore did occur, and index can be seen	jr	z,fres2		;Ok, drive is empty	ld	d,CDOR		;Ok, disk is in drive but door is openfres2:	ld	a,d	or	a		;Set nz	ret			;Return to caller	eject;	This special code moves drives 1,2 and 3 to track 0.  It does not;	care if they exist or notfl3:	cp	rinit		;Is it the bit restore?	jr	nz,fl31		;No, do something else	ld	b,4		;Set count	ld	d,1		;Set select for drive 0fl3lp:	call	hltfdc		;Shutdown the FDC	ld	a,d		;Get select value	out	(f_slct),a	;Select drive (we don't care about density)	rlca			;Rotate left	ld	d,a		;Save it	in	a,(f_stat)	;Look at drive	and	f_load		;Lose all but head load status	jr	z,fl3q		;Drive does not exist	xor	a		;Issue restore command	out	(f_cmd),a	;Do it	call	settle		;Settle onlyfl3x:	in	a,(f_stat)	;Check on progress	xor	f_busy		;Invert busy.  1 = not busy, 0 = busy	and	f_trk0+f_busy	;Look for Track 0 or not BUSY	jr	z,fl3x		;Not there, keep lookingfl3q:	djnz	fl3lp		;Loop till drives 1, 2 and 3 are done	ret			;Exit;	At this point, the command is either a seek or a read.;	For both, a seek must be done.fl31:	in	a,(f_cyl)	;Read track position	cp	e		;Is that where we want to be?	jr	z,fltrk		;Yes, so skip the seek/verify/delay	ld	a,e		;Get Track number	out	(f_data),a	;Tell it to go here	ld	a,f_seek	;Seek with 6 msec set	call	fboth		;[17-t 4.25 usec]Do a settle and a wait	ld	d,a		;Save status here for a moment	and	98h		;Test for Drive NR, Seek and CRC Error	jr	nz,erch3	;Seek had an errorfltrk:	ld	a,b	cp	read		;Was this a read or a seek?	jr	z,flr		;Then read	eject;	Here, the command was a seek and the seek checked for errorserch3:	ld	b,d		;Put error status in berch2:	ld	d,serr		;On a seek this would be a seek error	jr	erch1		;Enter error checkererrchk:	ld	d,fdld		;Test for lost data on read	bit	2,b		;Well?	jr	nz,fres2	;Drives too fast, code too slow				;Code is stable, must be hardware  <----	ld	d,fdid		;On a read this would be a ID errorerch1:	bit	4,b		;Was it Record Not Found or Seek Error?	jr	nz,fres2	ld	d,crce		;Try for CRC Error	bit	3,b		;Was it a CRC Error	jr	nz,fres2	ld	d,fdnr		;Force Drive not ready	bit	7,b		;Is the drive not ready?	jr	nz,fres2	xor	a		;Everything must have worked	ret			;Return sucessfully;	At this point, we are selected, and are positioned to the correct;	track.  Now, do the readflr:	ld	a,(disktype)	;0 is Ldos/Trsdos 6, 1 is TRSDOS 1.x	ld	b,a		;Put that here	ld	a,(sdh_i)	;Get the select we built	ld	d,a		;Put it here	ld	c,f_read	;Set the following:				;Read Sector				;Delay 15msec for settle				;Compare side information				;Side 1;	This code determines if we need to select side two	in	a,(f_sect)	;Get sector register	cp	17+1		;Is this on the second side?	jr	c,sideone	;Select side 1	sub	18		;Decrement sector value	set	4,d		;Set side two in hardware select	set	3,c		;Set side two in side compare	ejectsideone:add	a,b		;Fudge the sector number	out	(f_sect),a	;Give thd FDC the value again	ld	a,d		;Get hardware select	out	(f_slct),a	;Select side 2 (gives us 2 or 3 seconds)	ld	b,0		;Set 256 byte read	ld	e,h		;Reset multiple counter	ift	debug	di	ld	ix,(0067h)	;Get NMI target	push	hl		;Save HL again	ld	hl,nmiser	;Point to service address for nmi	ld	(0067h),hl	;Point NMI Vector to our code	pop	hl		;Put stack back	endif	ld	a,c		;Get the read command	ld	c,f_data	;Point at Data Register	out	(f_cmd),a	;Read a sector;	Put NMI ACtivate after Read Command To prevent false NMI's	ld	a,80h		;[4-t] Set NMI for INTRQ	out	(wrnmi),a	;[11-t] Set it now	call	settle		;Wait for FDC to lock	ld	a,d		;Get select value	out	(f_slct),a	;Select drive.  This gives about  2 to				;3 seconds from this point for readwtdrq1:	in	a,(f_stat)	;Read the FDC status	bit	1,a		;Test bit	jp	nz,start	;Wait for DRQ to come on	rlca			;Is drive still ready?	jp	nc,wtdrq1	;Wait but allow drive to time out	jr	rlp1		;Yes, Error Detectedstart:	ini			;Read the first byte;	Here we read the sector	ld	a,d		;Get select value	or	40h		;Set Hardware Waitsgtnxt:	out	(f_slct),a	;Force a wait on each byte	ini			;Read a byte from port (c)	jr	gtnxt		;[12-t on jump] Get next byte;	This loop will exit to nmiser on end-of-command signal from FDC	eject;	This code is entered via the NMI Interruptnmiser:	pop	bc		;Lose the place that called us	xor	a		;Turn off NMI	out	(wrnmi),a	;Now	ift	debug	ld	(0067h),ix	;Put old NMI value back	endifrlp1:	in	a,(f_stat)	;[11-t] Read status register	ift	debug	ei	endif	ld	b,a		;Put a copy of the status here;	ld	c,b		;Make it the previous status too	call	retn		;Fix up interrupts	ld	a,h		;Get msb of destination	sub	e		;Subtract starting point	ld	e,a		;Store 256 multiple	iff	debug	jr	errchk		;Test for any errors	else	jp	errchk		;Test for any errors	endifretn:	retn;	This routine takes 36 usec to call, execute and return;	which is enough for the controller to accept a command;	This value is greater than 32 usec for a force interrupt;	and 28 usec for valid data in all status register bits.;**	Apparently Tandy is buying really crummy FDC's and they need much;	more to work properly.hltfdc:	ld	a,0d0h		;Stop any activity on drive	out	(f_cmd),a	;Now	push	bc	ld	b,0	jr	setup		;FDC has a problem. Force Interrupt takes				;many times longer than WD manual sayssettle:	push	bc		;[11-t 2.75 usec]	ld	b,19		;[7-t 1.75 usec]setup:	djnz	setup		;[B<>0 13-t 3.25 usec]				;[B=0 8-t 2.0 usec]	pop	bc		;[10-t 2.5 usec]	ret			;[10-t 2.5 usec];	This routine calls settle and waitfboth:	out	(f_cmd),a	;Issue command we were given	call	settle		;Wait for command to sink in;	This routine wait for busy to drop or time to pass	ld	c,0		;Clear previous status bytewait:	in	a,(f_stat)	;Test busy status	bit	0,a		;Is command still in progress?	ret	z	bit	7,a		;How about, not ready?	ret	nz	ld	c,a		;Save previous status - used in	jr	wait		;stating what drive looks like