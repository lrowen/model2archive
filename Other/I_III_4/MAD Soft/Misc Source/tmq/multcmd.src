	title	'Multicmd (MCM) - Executes numerous commands from one line'	print	short,nomac		;Source packed for compact printing.	psect	7800h			;Below 32K and well out of the way.;----------------------------------------------------------------------------greet:	defm	'Multicmd (MCM) - Multiple command executor - '	defm	'Version   1(1) 9-Jun-90   '	defb	0ah			;For TRSDOS 6 / LS-DOS 6	defm	'Copyright 1981, 1990  Frank Durda IV, All Rights Reserved.'	defb	0dh;	You are free to reproduce and modify this program provided the copy-;	right strings and related code are not disturbed.  This program is;	provided "as is".  The author can be reached electronically via;	USENET at:	...texbell!rwsys!nemesis!z80mail;		or	...microsoft!trsvax!hal6000!nemesis!z80mail   006091;----------------------------------------------------------------------------;  OVERVIEW:;	This program accepts one or more commands and executes them via the;	@cmndr svc.  After each command completes, the next command is execu-;	ted until all are performed.  The usage lines for this program is:usage:	defm	'Usage:  MCM [-v] command 1 [; command 2] [; command 3]'	defb	0dh;	The -v echos each command as it is executed for debugging purposes.;----------------------------------------------------------------------------stackr:	equ	1			;A '1' equ places program on stack.					;MCM can't be overwritten, but it					;does not leave very much stack left.					;A '0' equ disables this feature.@dsply:	equ	10			;Display a string.@abort:	equ	21			;Abort execution.@exit:	equ	22			;Exit this program.@cmndi:	equ	24			;Issue a command and don't come back.@cmndr:	equ	25			;Issue a command and come back.lsdos	macro	#1	ld	a,#1	rst	28h	endm;	We begin here.  LS-DOS gives us HL pointing at the first item after;	the program name in the system command buffer.  First, we make a copy.begin:	ld	de,ourbuf		;Make copy of system command buffer.	ld	bc,80			;Copy entire length, although some	ldir				;of the data copied is useless.	ld	hl,ourbuf		;Use our buffer from now on.begina:	ld	a,(hl)			;Start test for options.	cp	' '			;Test for and skip any spaces.	jr	z,skipsp		;Spaces are ignored.	cp	'-'			;Now that we have a non-space, is it	jr	nz,endopt		;a option flag?  If not, handle	inc	hl			;the first command.	ld	a,(hl)			;Get option code;	Here we read the option(s) that have been located.  If you want to;	add other option switches, the tests go here.	cp	'V'			;Test for Verbose option.	jr	z,goverb		;We have a match.	cp	'v'			;Check for lowercase since it can	jr	nz,badopt		;be received in either case.goverb:	ld	(verbose),a		;Set verbose flag to non-zero value.skipsp:	inc	hl			;Advance to the next character.	jr	begina			;Look for other options.;	Here we have a switch that we don't know about, so display an error.badopt:	ld	hl,usage		;Point at  usage-line message.	lsdos	@dsply			;Display it.	lsdos	@abort			;Abort execution.;	We have processed all the switches, so start handling the commands.endopt:	ld	a,(verbose)		;Determine if we should print the	or	a			;titles.	jr	z,movcore		;No, skip printing that.	push	hl			;Save command pointer for a second.	ld	hl,greet		;Point at title.	lsdos	@dsply			;Display it.	pop	hl			;Get back command pointer.;	This code copies the part of the program that processes commands;	into an area below the current stack pointer, then moves the stack;	pointer below that point.  This provides a safe base to execute the;	program from, without having to worry about what part of memory a;	given command or program may use.  For example, one of your commands;	could be MEMORY (CLEAR) and MCM would continue working.  The down-side;	of this is that we use about 145 bytes of stack, leaving very;	little for other programs.  At the top of the program is a switch that;	disables placing the program in the stack.movcore:	ift	stackr	push	hl			;Save command pointer.	ld	hl,0ffffh		;Subtract 1 from address given.	add	hl,sp			;Get current stack position -1.	ld	de,edcore		;Get address of last byte of core.	ex	de,hl			;HL = Last byte of core region.					;DE = SP start (last) of stack area.	ld	bc,lncore		;Get size of core area.	di	;------------------------Interrupts must be disabled					;while we manipulate the stack.	lddr				;Transfer core pgm into the stack.	inc	de			;Get entry address to relocated mod.	pop	hl			;Get back command buffer pointer.	ld	bc,stcore		;Compute address of copy of buffer	or	a			;that is now in the stack area.	sbc	hl,bc			;orig ptr - orig core base = offset	add	hl,de			;offset + new core base = new pointer	ex	de,hl			;HL = start of relocated core.					;DE = pointer to first command to do.	ld	sp,hl			;Set stack to protect our code.	ei	;------------------------Interrupts can now be enabled.	jp	(hl)			;Jump to relocated code (below).;	This is the running core which breaks the commands apart and;	passes them to the O/S.  It uses relative addressing so it can;	be relocated on-the-fly.stcore:	equ	$			;Start of code to be relocated.	ex	de,hl			;Move command pointer to HL.	endifskipblk:ld	a,(hl)			;Pick up the next character.	cp	' '			;Is it a leading space?.	jr	nz,fstchar		;No, this is first char of command.skiplp:	inc	hl			;Skip byte and move to next.	jr	skipblk	fstchar:push	hl			;Save start of command. Now find end.looknxt:ld	a,(hl)			;Get next character.	cp	0dh			;Have we reached the end of line?	jr	z,fndlcmd		;End of command has been found.	cp	';'			;Is this the end of a single command?	jr	z,docmd			;Yes,end of single command.	inc	hl			;Keep looking, bump to next character	jr	looknxtdocmd:	ld	(hl),0dh		;Change ; into a RETURN.	ex	(sp),hl			;Get back starting point for this					;command and save end of this command.	ld	a,(verbose)		;Should we echo the command.	or	a			;we are about to execute.	jr	z,quiet1		;No, don't display anything.	push	hl			;Save HL (start of command).	lsdos	@dsply			;Display it.	pop	hl			;Restore HL (start of command).quiet1:	lsdos	@cmndr			;Execute the command we separated.	ld	a,h			;Did the command return a NZ error	or	l			;code in HL?  If so, don't continue.	pop	hl			;Get back pointer to end of previous					;command (now start of next command).	jr	z,skiplp		;Handle next command.	lsdos	@exit			;Pass error code to our invoker.;	Execute the last command on the line and exit this program.fndlcmd:pop	hl			;Get back pointer to start of cmd.	ld	a,(verbose)		;Should we echo the command.	or	a			;we are about to execute.	jr	z,quiet2		;No, don't display anything.	push	hl			;Save HL (start of command).	lsdos	@dsply			;Display it.	pop	hl			;Restore HL (start of command).quiet2:	lsdos	@cmndi			;Execute the last command.	;================================The @cmndi call does not return.ourbuf:	defb	80%0			;Our command buffer.verbose:defb	0			;Quiet or noisy execution flag.	ift	stackrlncore:	equ	$-stcore		;Size of area to relocate.edcore:	equ	$-1			;End of area to relocate.	endif	end	begin			;begin is first instruction to do.