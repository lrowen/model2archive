	title	'Multicmd (MCM) - Executes numerous commands from one line'	print	shortourbase:equ	7800h			;Below 32K and well out of the way.	psect	ourbase;----------------------------------------------------------------------------;	Multicmd (MCM), Copyright 1981 and 1990 Frank Durda IV, All;	Rights Reserved.  You are free to reproduce and modify this program;	provided the copyright comments, strings and related code are not;	disturbed.  The program is provided "as is" and you are entirely on;	your own.  The author can be reached electronically via USENET at:;		...texbell!rwsys!nemesis!uhclem;		...microsoft!trsvax!hal6000!nemesis!uhclem;								006091;----------------------------------------------------------------------------;  OVERVIEW:;	This program accepts one or more commands and executes them via the;	@cmndr svc.  After each command completes, the next command is execu-;	ted until all are performed.  The usage lines for this program is:;		MCM [-v] command 1 [; command 2] [; command 3] ...;	The -v echos each command as it is executed for debugging purposes.;----------------------------------------------------------------------------	eject@dsply:	equ	10			;Display a string@abort:	equ	21			;Abort execution@exit:	equ	22			;Exit@cmndi:	equ	24			;Issue a command and don't come back@cmndr:	equ	25			;Issue a command and come backlsdos	macro	#1	ld	a,#1	rst	28h	endm;	Edit EDIT Version VERSIONgreet:	defm	'Multicmd - Multiple command executor - '	defm	'Version   1(1) 9-Jun-90   '	defb	0ah	defm	'Copyright 1981, 1990  Frank Durda IV, '	defm	'All Rights Reserved.'	defb	0dh	ejectbegin:	ld	de,ourbuf		;Make copy of system command buffer	ld	bc,80			;Copy entire length	ldir	ld	hl,ourbuf		;Use our buffer from now onbegina:	ld	a,(hl)			;Start test for options	cp	' '			;Test for and skip any spaces	jr	z,skipsp		;Leading spaces are ignored;	cp	'<'			;Test for redirection;	jr	z,goredir	cp	'-'			;Now that we have a non-space, is it	jr	nz,endopt		;a option flag?  If not, handle					;the first command.;	Here we read the option(s) has been located.mopt:	inc	hl	ld	a,(hl)			;Get option code	cp	'V'			;Test for Verbose option	jr	z,goverb	cp	'v'	jr	nz,badopt;	Note that we found the Verbose switch.  Then look for other switches.goverb:	inc	hl			;Bump beyond flag	ld	(verbose),a		;Set non-zeroskipsp:	inc	hl			;Advance to the next character	jr	begina;	We have processed all the switches, so start handling the commandsendopt:	ld	a,(verbose)		;Determine if we should print the	or	a			;titles.	jr	z,skipblk		;No, skip printing that.	push	hl			;Save command pointer for a second.	ld	hl,greet		;Point at title.	lsdos	@dsply			;Display it.	pop	hl			;Get back command pointer.	jr	skipblk			;Now start separating commands.skiplp:	inc	hl			;Advance command-line pointerskipblk:ld	a,(hl)			;Pick up the next character	cp	' '			;Is it a leading space?	jr	z,skiplp		;If so, skip it.	push	hl			;Save start of commandlooknxt:ld	a,(hl)			;Get next character	cp	0dh			;Have we reached the end of line?	jr	z,fndlcmd		;End of command has been found	cp	';'			;Is this the end of a single command	jr	z,docmd			;End of command	inc	hl			;Bump to next character	jr	looknxtdocmd:	ld	(hl),0dh		;Change ; into a RETURN	ex	(sp),hl			;Get back starting point for this					;command and save end of this command	call	echo			;Echo the command (if verbose is on)	lsdos	@cmndr			;Execute the command we separated.	ld	a,h			;Did the command return a NZ error	or	l			;code in HL?  If so, don't process.	pop	hl			;Get back pointer to end of previous					;command (now start of next command).	jr	z,skiplp		;Handle next command.	lsdos	@exit			;Pass error code to our invoker;	Execute the last command on the line and exit this program.fndlcmd:pop	hl			;Get back pointer to start of cmd.	call	echo			;Echo the command (if verbose is on)	lsdos	@cmndi			;Execute the last command					;This call does not returnbadopt:	ld	hl,bad1msg		;Point at  usage-line message	lsdos	@dsply			;Display itbomboff:lsdos	@abort			;Abort execution;	This routine echos the command that is to be executed if;	the -v option was specified on the command line.echo:	ld	a,(verbose)		;Should we echo the command 	or	a			;we are about to execute.	ret	z			;No, don't display anything	push	hl			;Save HL (start of command)	lsdos	@dsply			;Display it	pop	hl			;Restore HL (start of command)	ret				;Return to caller.;----------------------------------------------------------------------------;	Utility messages and data;----------------------------------------------------------------------------bad1msg:defm	'Usage:  MCM [-v] command 1 [; command 2] [; command 3]'	defb	0dhourbuf:	defb	80%0			;Our command bufferverbose:defb	0			;Quiet or noisy execution	end	begin